@if (TempData["CheckInSuccess"] != null)
{
    var cashChangeFormatted = TempData["CashChangeFormatted"] as string ?? "₱0.00";
    var extendBalanceFormatted = TempData["ExtendBalanceFormatted"] as string ?? "₱0.00";

    // Parse the values to check if they are zero
    var cashChangeValue = 0m;
    var extendBalanceValue = 0m;
    try {
        var cashChangeStr = TempData["CashChangeFormatted"]?.ToString() ?? "";
        var extendBalanceStr = TempData["ExtendBalanceFormatted"]?.ToString() ?? "";

        // Clean the strings: remove currency symbols, commas, and trim whitespace
        cashChangeStr = System.Text.RegularExpressions.Regex.Replace(cashChangeStr, @"[^\d.-]", "");
        extendBalanceStr = System.Text.RegularExpressions.Regex.Replace(extendBalanceStr, @"[^\d.-]", "");

        decimal.TryParse(cashChangeStr, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out cashChangeValue);
        decimal.TryParse(extendBalanceStr, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out extendBalanceValue);
    } catch { }

    // Show extend balance and cash change rows only if either has a value > 0
    // Hide both if both are 0 (fully paid without outstanding balance)
    var showExtendBalance = extendBalanceValue > 0;
    var showCashChange = cashChangeValue > 0;
    var showPaymentDetails = showExtendBalance || showCashChange;

    <div class="modal fade" id="checkInSuccessModal" tabindex="-1" aria-labelledby="checkInSuccessModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="checkInSuccessModalLabel">Check-In Successful</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-center mb-4">Reservation has been checked in successfully!</p>
                    <table class="table table-borderless">
                        <tr>
                            <td style="width: 50%; font-weight: 500;">Status:</td>
                            <td style="width: 50%; text-align: right;"><strong>Checked-In</strong></td>
                        </tr>
                        @if (showExtendBalance)
                        {
                            <tr>
                                <td style="width: 50%; font-weight: 500;">Extend Balance:</td>
                                <td style="width: 50%; text-align: right;"><strong>@extendBalanceFormatted</strong></td>
                            </tr>
                        }
                        @if (showCashChange)
                        {
                            <tr>
                                <td style="width: 50%; font-weight: 500;">Cash Change:</td>
                                <td style="width: 50%; text-align: right;"><strong>@cashChangeFormatted</strong></td>
                            </tr>
                        }
                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        window.addEventListener('DOMContentLoaded', function () {
            try {
                var m = document.getElementById('checkInSuccessModal');
                if (m) {
                    var inst = new bootstrap.Modal(m);
                    inst.show();
                }
            } catch (e) { console.error(e); }
        });
    </script>
}

<!-- Check Out Price Modal -->
@foreach (var booking in reservationsList)
{
    <!-- Quick Check-In Confirmation Modal (shows total and asks for confirmation) -->
    <div class="modal fade" id="confirmCheckinModal-@booking.Id" tabindex="-1" aria-labelledby="confirmCheckinModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmCheckinModalLabel-@booking.Id">Confirm Check-In</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Confirm the check in for this reservation?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary confirm-checkin-btn" data-booking-id="@booking.Id">Check In Now</button>
                </div>
            </div>
        </div>
    </div>
    // Safely parse RoomRates which may be null/empty or non-numeric in some records.
    decimal roomRatesDecimal = 0m;
    // Try current culture first, then invariant as a fallback
    decimal.TryParse(Convert.ToString(booking.RoomRates), System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.CurrentCulture, out roomRatesDecimal);
    if (roomRatesDecimal == 0m)
    {
        decimal.TryParse(Convert.ToString(booking.RoomRates), System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out roomRatesDecimal);
    }
    var stayingDays = (booking.DepartureDate - booking.ArrivalDate).Days; 
    var total = stayingDays * roomRatesDecimal;
    <span id="extendExtendBalanceRaw-@booking.Id" style="display:none">@booking.ExtendBalance</span>
    <div class="modal fade" id="checkoutPriceModal-@booking.Id" tabindex="-1" aria-labelledby="checkoutPriceModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="checkoutPriceModalLabel-@booking.Id">Check Out Reservation</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <dl class="row">
                        <dt class="col-sm-3">Reservation ID</dt>
                        <dd class="col-sm-9">@booking.Id</dd>
                        <dt class="col-sm-3">First Name</dt>
                        <dd class="col-sm-9">@booking.FirstName</dd>
                        <dt class="col-sm-3">Last Name</dt>
                        <dd class="col-sm-9">@booking.LastName</dd>
                        <dt class="col-sm-3">Book/Reserve</dt>
                        <dd class="col-sm-9">@booking.BookReserve</dd>
                        <dt class="col-sm-3">Check-In Date</dt>
                        <dd class="col-sm-9">@(booking.ArrivalDate.Year <= 1 ? string.Empty : booking.ArrivalDate.ToString("yyyy-MM-dd"))</dd>
                        <dt class="col-sm-3">Check-Out Date</dt>
                        <dd class="col-sm-9">@(booking.DepartureDate.Year <= 1 ? string.Empty : booking.DepartureDate.ToString("yyyy-MM-dd"))</dd>
                        <dt class="col-sm-3">Room Number</dt>
                        <dd class="col-sm-9">@booking.RoomNumber</dd>
                        <dt class="col-sm-3">Room Type</dt>
                        <dd class="col-sm-9">@booking.RoomType</dd>
                        <dt class="col-sm-3">Paid Reservation</dt>
                        <dd class="col-sm-9"><b>@booking.PaidReserve.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</b></dd>
                    </dl class="row">
                    ----------------------------------------------------------
                    <dl class="row">
                        <dt class="col-sm-5">Number of Pax</dt>
                        <dd class="col-sm-7">@booking.NumberOfPax.ToString()</dd>
                        <dt class="col-sm-5">Room Rates</dt>
                        <dd class="col-sm-7">@roomRatesDecimal.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</dd>
                        <dt class="col-sm-5">Staying Days</dt>
                        <dd class="col-sm-7">@stayingDays.ToString() nights</dd>
                        <dt class="col-sm-5">ExtendBalance</dt>
                        <dd class="col-sm-7"><b>@booking.ExtendBalance.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</b></dd>
                    </dl>

                    Do you want to check out this selected reservaton?<br/>
                    This action cannot be undone.
                </div>
                <div class="modal-footer">
                    <!-- remove automatic BS toggles and use class + data attribute for JS control -->
                    <button type="button" class="btn btn-success open-payment-btn" data-booking-id="@booking.Id" data-book-reserve="@booking.BookReserve">Check Out Now</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Direct Check-In Form (hidden). Submits directly without payment modal -->
    <form asp-action="CheckInReservation" asp-controller="System" method="post" id="directCheckinForm-@booking.Id" style="display:none;">
        <input type="hidden" name="Id" value="@booking.Id" />
        <input type="hidden" name="ArrivalDate" value="@(booking.ArrivalDate.Year <= 1 ? string.Empty : booking.ArrivalDate.ToString("yyyy-MM-dd"))" />
        <input type="hidden" name="DepartureDate" value="@(booking.DepartureDate.Year <= 1 ? string.Empty : booking.DepartureDate.ToString("yyyy-MM-dd"))" />
        <input type="hidden" name="RoomType" value="@booking.RoomType" />
        <input type="hidden" name="RoomNumber" value="@booking.RoomNumber" />
        <input type="hidden" name="RoomRates" value="@booking.RoomRates" />
        <input type="hidden" name="NumberOfPax" value="@booking.NumberOfPax" />
        <input type="hidden" name="GuestNames" value="@booking.GuestNames" />
    </form>

    <!-- Check-Out Payment Modal (for checkout flows) -->
    <div class="modal fade" id="checkoutPaymentModal-@booking.Id" tabindex="-1" aria-labelledby="checkoutPaymentModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="checkoutPaymentModalLabel-@booking.Id">Payment Check Out - Reservation @booking.Id</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @{
                        decimal initialTotalForDisplayCheckout = Convert.ToDecimal(total);
                        try
                        {
                            var rawBalObj = booking.ExtendBalance;
                            double parsedBal = 0;
                            if (rawBalObj != null) double.TryParse(Convert.ToString(rawBalObj), out parsedBal);
                            if (parsedBal > 0)
                            {
                                initialTotalForDisplayCheckout = Convert.ToDecimal(parsedBal);
                            }
                        }
                        catch { }
                    }

                    <div class="mb-2">Total Amount: <strong id="checkoutDisplayTotal-@booking.Id">@initialTotalForDisplayCheckout.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</strong></div>

                    <div class="mb-3" id="checkoutPayAmountContainer-@booking.Id">
                        <label for="checkoutPayAmountInput-@booking.Id" class="form-label">Enter Pay Amount</label>
                        <input type="number" step="0.01" min="0" class="form-control" id="checkoutPayAmountInput-@booking.Id" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Amount Change</label>
                        <div id="checkoutChangeDisplay-@booking.Id" class="fw-bold">@(0.ToString("C2", new System.Globalization.CultureInfo("en-PH")))</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <!-- Reservation flow: checkout form -->
                    <form asp-action="CheckOutReserve" asp-controller="System" asp-route-reservationId="@booking.Id" method="post" id="checkoutPaymentForm-@booking.Id">
                        <input type="hidden" name="stayingDays" value="@stayingDays" />
                        <input type="hidden" name="grandTotal" value="@initialTotalForDisplayCheckout" id="checkoutGrandTotalHidden-@booking.Id" />
                        <input type="hidden" name="cashAmount" id="checkoutPayHiddenAmount-@booking.Id" />
                        <input type="hidden" name="cashChange" id="checkoutPayHiddenChange-@booking.Id" />
                        <button type="submit" class="btn btn-success" id="checkoutPayBtn-@booking.Id">Pay</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Direct checkout form for bookings (hidden). This uses booking's stored cash values so payment modal is skipped for Bookings -->
    <form asp-action="CheckOut" asp-controller="System" asp-route-bookingId="@booking.Id" method="post" id="directCheckoutForm-@booking.Id" style="display:none;">
        <input type="hidden" name="stayingDays" value="@stayingDays" />
        <input type="hidden" name="grandTotal" value="@total" />
    </form>

    <!-- Extend Stay Modal -->
    <div class="modal fade" id="extendStayModal-@booking.Id" tabindex="-1" aria-labelledby="extendStayModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="extendStayModalLabel-@booking.Id">Extend Stay - Reservation @booking.Id</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label"><strong>Original Check-Out Date</strong></label>
                        <div>@(booking.DepartureDate.Year <= 1 ? string.Empty : booking.DepartureDate.ToString("yyyy-MM-dd"))</div>
                    </div>
                    <div class="mb-3">
                        <label for="extendNewCheckoutDate-@booking.Id" class="form-label">Choose new Check-Out Date</label>
                        <input type="date" class="form-control extend-new-checkout-date" id="extendNewCheckoutDate-@booking.Id" data-original-checkout="@(booking.DepartureDate.Year <= 1 ? string.Empty : booking.DepartureDate.ToString("yyyy-MM-dd"))" />
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold">Extended Nights</label><div id="extendNightsDisplay-@booking.Id">0</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary extend-now-btn" data-booking-id="@booking.Id">Extend Now</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Extend Payment Modal -->
    <div class="modal fade" id="extendPaymentModal-@booking.Id" tabindex="-1" aria-labelledby="extendPaymentModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="extendPaymentModalLabel-@booking.Id">Extend Payment - Reservation @booking.Id</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label"><strong>New Check-Out Date</strong></label>
                        <div id="extendPayNewCheckoutDate-@booking.Id"></div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label"><strong>Room Rate</strong></label>
                        <div id="extendPayRoomRate-@booking.Id"></div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label"><strong>Extended Nights</strong></label>
                        <div id="extendPayExtendedNights-@booking.Id"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><strong>Extended Price</strong></label>
                        <div id="extendPayExtendedPrice-@booking.Id"></div>
                    </div>
                    <div class="mb-3" id="extendPayAmountContainer-@booking.Id">
                        <label for="extendPayAmountInput-@booking.Id" class="form-label">Enter Pay Amount</label>
                        <input type="number" step="0.01" min="0" class="form-control" id="extendPayAmountInput-@booking.Id" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><strong>Amount Balance</strong></label>
                        <div id="extendPayBalanceDisplay-@booking.Id" class="fw-bold">₱0.00</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><strong>Amount Change</strong></label>
                        <div id="extendPayChangeDisplay-@booking.Id" class="fw-bold">₱0.00</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <form asp-action="ExtendStay" asp-controller="System" method="post" id="extendPaymentForm-@booking.Id">
                        <input type="hidden" name="bookingId" value="@booking.Id" />
                        <input type="hidden" name="newCheckoutDate" id="extendHiddenNewCheckoutDate-@booking.Id" />
                        <input type="hidden" name="extendedNights" id="extendHiddenExtendedNights-@booking.Id" />
                        <input type="hidden" name="extendedPrice" id="extendHiddenExtendedPrice-@booking.Id" />
                        <input type="hidden" name="payAmount" id="extendHiddenPayAmount-@booking.Id" />
                        <input type="hidden" name="extendBalance" id="extendHiddenExtendBalance-@booking.Id" />
                        <input type="hidden" name="changeAmount" id="extendHiddenChangeAmount-@booking.Id" />
                        <button type="submit" class="btn btn-success extend-pay-btn" id="extendPayBtn-@booking.Id">Pay</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

