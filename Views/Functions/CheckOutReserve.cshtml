                var changeCandidates = [document.getElementById('extendChangeDisplay-' + bookingId), document.getElementById('extendChangeDisplayExt-' + bookingId)];
                var changeEl = (changeCandidates.find && changeCandidates.find(function (el) { try { return el && (el.offsetParent !== null || (el.getClientRects && el.getClientRects().length > 0)); } catch (e) { return false; } })) || changeCandidates[0];
                if (changeEl) changeEl.textContent = currencyFormatter.format(change);
                // also update the generic payment displayChange if present
                var genericChange = document.getElementById('displayChange-' + bookingId);
                if (genericChange) genericChange.textContent = currencyFormatter.format(change < 0 ? 0 : change);
            } catch (err) { console.error(err); }

            // update Balance display: show remaining amount (zero if fully paid)
            try {
                // update whichever balance element is visible (payment modal or extend-payment modal)
                var payAppliedCandidates = [document.getElementById('extendPayApplied-' + bookingId), document.getElementById('extendPayAppliedExt-' + bookingId)];
                var payAppliedEl = (payAppliedCandidates.find && payAppliedCandidates.find(function (el) { try { return el && (el.offsetParent !== null || (el.getClientRects && el.getClientRects().length > 0)); } catch (e) { return false; } })) || payAppliedCandidates[0];
                if (payAppliedEl) {
