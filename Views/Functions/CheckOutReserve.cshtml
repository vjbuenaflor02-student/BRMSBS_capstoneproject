            // Determine price: prefer extendPrice (for extend flow), otherwise fall back to grandTotalHidden (payment flow)
            var price = 0;
            // preferred: extendPrice (extend flow)
            var priceEl = document.getElementById('extendPrice-' + bookingId);
            if (priceEl && (priceEl.textContent || priceEl.innerText)) {
                var priceText = priceEl.textContent || priceEl.innerText || '';
                price = parseFloat(priceText.replace(/[^0-9.-]+/g, '') || '0');
            }

            // fallback: hidden grand total field (payment flow)
            if (!price || price === 0) {
                var grandEl = document.getElementById('grandTotalHidden-' + bookingId);
                if (grandEl) price = parseFloat((grandEl.value || '').toString().replace(/[^0-9.-]+/g, '') || '0') || 0;
            }

            // final fallback: displayTotal element (formatted with currency)
            if (!price || price === 0) {
                var displayTotalEl = document.getElementById('displayTotal-' + bookingId);
                if (displayTotalEl) {
                    var dt = (displayTotalEl.textContent || displayTotalEl.innerText || '').toString();
                    price = parseFloat(dt.replace(/[^0-9.-]+/g, '') || '0') || 0;
                }
            }

            // last resort: extendBalanceRaw (hidden span)
            if (!price || price === 0) {
                try {
                    var rawBalEl = document.getElementById('extendBalanceRaw-' + bookingId);
                    if (rawBalEl) {
                        var rawVal = (rawBalEl.textContent || rawBalEl.innerText || rawBalEl.value || '').replace(/[^0-9.-]+/g, '');
                        price = parseFloat(rawVal || '0') || 0;
                    }
                } catch (e) { }
            }

            var enteredRaw = (target.value || '').toString();
            var entered = parseFloat(enteredRaw || '0');
            if (isNaN(price)) price = 0;
            if (isNaN(entered)) entered = 0;

            // use rounded values for comparison to avoid floating precision issues
            var priceRounded = Math.round(price * 100) / 100;
            var enteredRounded = Math.round(entered * 100) / 100;

            // If user hasn't entered any value, show zero balance/change by default
            var remaining = 0;
            var change = 0;
            var hasValue = enteredRaw.trim() !== '';
            if (hasValue) {
                remaining = priceRounded - enteredRounded;
                if (isNaN(remaining) || remaining < 0) remaining = 0;

                change = enteredRounded - priceRounded;
                if (isNaN(change) || change < 0) change = 0;
            }

            // enable Pay when entered amount meets a minimum threshold.
            // Business rule: require at least PHP 750 to enable Pay, unless the extended price is less than 750
            // (in which case require the full extended price).
            var minToEnable = priceRounded <= 750 ? priceRounded : 750;

            // Find the correct Pay button tied to this booking: prefer the visible submit button
            var payNowBtn = null;
            try {
                var paymentForm = document.getElementById('paymentForm-' + bookingId);
                var extendForm = document.getElementById('extendPayForm-' + bookingId);
                var candidates = [];
                if (paymentForm) candidates = candidates.concat(Array.from(paymentForm.querySelectorAll('button[type="submit"]')));
                if (extendForm) candidates = candidates.concat(Array.from(extendForm.querySelectorAll('button[type="submit"]')));
                // choose the first visible candidate
                for (var i = 0; i < candidates.length; i++) {
                    var c = candidates[i];
                    if (!c) continue;
                    // visible check: offsetParent may be null when hidden, but also check getClientRects
                    var visible = (c.offsetParent !== null) || (c.getClientRects && c.getClientRects().length > 0);
                    if (visible) { payNowBtn = c; break; }
                }
                // fallback to id-based lookup if no candidate found
                if (!payNowBtn) payNowBtn = document.getElementById('extendPayNowBtn-' + bookingId);
            } catch (er) { payNowBtn = document.getElementById('extendPayNowBtn-' + bookingId); }

