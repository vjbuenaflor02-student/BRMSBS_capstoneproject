                setText('confirmRoomType', roomType);
                setText('confirmRoomRates', formatCurrencyPH(rateNum));
                setText('confirmPax', pax);
                setText('confirmTotal', formatCurrencyPH(total) + (nights > 0 ? (' (' + nights + ' night' + (nights > 1 ? 's' : '') + ')') : ''));

                // ensure hidden fields are set so server receives values when form is submitted
                var formRoomHidden = document.getElementById('formRoomNumber-' + bid);
                if (formRoomHidden) formRoomHidden.value = roomNumber;
                var formCheckoutHidden = document.getElementById('formCheckoutDate-' + bid);
                if (formCheckoutHidden) formCheckoutHidden.value = checkout;

                // hide checkin modal and show confirmation modal
                try {
                    var checkinModalEl = document.getElementById('checkinModal-' + bid);
                    var cm = bootstrap.Modal.getInstance(checkinModalEl) || bootstrap.Modal.getOrCreateInstance(checkinModalEl);
                    if (cm) cm.hide();
                } catch (ex) { }

                var confirmEl = document.getElementById('confirmCheckinModal-' + bid);
                if (confirmEl) {
                    try { var inst = bootstrap.Modal.getOrCreateInstance(confirmEl); inst.show(); } catch (err) { console.error(err); }
                }
            } catch (err) { console.error(err); }
        });

        // When user clicks "Reserve Now" on confirm modal, show the payment modal
        // instead of immediately submitting the form. This allows the operator to
        // enter payment and see change. The payment modal already posts the checkout.
        document.addEventListener('click', function (e) {
            try {
                var btn = e.target.closest && e.target.closest('.confirm-checkin-btn');
                if (!btn) return;
                var bookingId = btn.getAttribute('data-booking-id');
                if (!bookingId) return;

                // locate confirm modal and payment modal for this booking
                var confirmEl = document.getElementById('confirmCheckinModal-' + bookingId);
                var paymentEl = document.getElementById('paymentModal-' + bookingId);

                // try to obtain the computed total from the confirm modal
                var confTotalEl = document.getElementById('confirmTotal-' + bookingId);
                var displayTotalEl = document.getElementById('displayTotal-' + bookingId);
                var grandHiddenEl = document.getElementById('grandTotalHidden-' + bookingId);
                var totalNum = 0;
                if (confTotalEl) {
                    try {
                        var txt = (confTotalEl.textContent || confTotalEl.innerText || '').toString();
                        // confirm total may include currency and text like " (2 nights)", strip non-numeric
                        var cleaned = txt.replace(/[^0-9.-]+/g, '') || '0';
                        totalNum = parseFloat(cleaned) || 0;
                    } catch (ex) { totalNum = 0; }
                }

                // update payment modal display and hidden grand total
                try { if (displayTotalEl) displayTotalEl.textContent = currencyFormatter.format(totalNum); } catch (e) { }
                try { if (grandHiddenEl) grandHiddenEl.value = totalNum; } catch (e) { }

                // Populate reservation-specific hidden inputs on the payment form (if present)
                try {
                    var paymentForm = document.getElementById('paymentForm-' + bookingId);
                    if (paymentForm) {
                        var getText = function(id) { try { var el = document.getElementById(id + '-' + bookingId); return (el && (el.textContent || el.value || el.innerText)) ? (el.textContent || el.value || el.innerText) : ''; } catch (e) { return ''; } };
                        var chkIn = getText('confirmCheckinDate');
                        var chkOut = getText('confirmCheckoutDate');
                        var rNum = getText('confirmRoomNumber');
                        var rType = getText('confirmRoomType');
                        var rRates = getText('confirmRoomRates');
                        var rPax = getText('confirmPax');
                        var gNames = getText('confirmGuestNames');

                        var setHidden = function(name, val) { try { var el = paymentForm.querySelector('[name="' + name + '"]'); if (el) el.value = val; } catch (e) {} };
                        setHidden('ArrivalDate', chkIn);
                        setHidden('DepartureDate', chkOut);
                        setHidden('RoomType', rType);
                        setHidden('RoomNumber', rNum);
                        setHidden('RoomRates', (rRates || '').toString().replace(/[^0-9.-]+/g, '') || '0');
                        setHidden('NumberOfPax', (rPax || '').toString().replace(/[^0-9.-]+/g, '') || '0');
                        setHidden('GuestNames', gNames || '');
                        setHidden('Total', totalNum || 0);

                        // initialize balance/change/paid fields if present
                        try {
                            var payInput = document.getElementById('payAmountInput-' + bookingId);
                            var entered = payInput ? parseFloat(payInput.value || '0') : 0;
                            var remainingInit = Math.max(0, (totalNum || 0) - entered);
                            setHidden('Balance', remainingInit);
                            setHidden('ChangeReserve', Math.max(0, entered - (totalNum || 0)));
                            setHidden('PaidReserve', entered || 0);
                        } catch (e) { }
                    }
                } catch (e) { console.error(e); }

                // hide confirm modal then show payment modal
                try {
                    if (confirmEl) {
                        var cm = bootstrap.Modal.getInstance(confirmEl) || bootstrap.Modal.getOrCreateInstance(confirmEl);
                        if (cm) cm.hide();
                    }
                } catch (ex) { }

                if (paymentEl) {
                    try {
                        var pinst = bootstrap.Modal.getOrCreateInstance(paymentEl);
                        pinst.show();
                        setTimeout(function () {
                            var cashInput = document.getElementById('cashAmount-' + bookingId);
                            if (cashInput) {
                                cashInput.focus();
                                try { if (typeof updateChangeFor === 'function') updateChangeFor(bookingId); } catch (e) { }
                            }
                        }, 120);
                    } catch (err) { console.error(err); }
                }
            } catch (e) { console.error(e); }
        });

        // Expose computeExtendedNights to global scope so delegated handlers defined
        // outside this IIFE can call it (some handlers are added in separate <script> blocks).
        try {
            if (typeof window !== 'undefined' && typeof computeExtendedNights === 'function') {
                window.computeExtendedNights = computeExtendedNights;
            }
        } catch (e) { console.error('expose computeExtendedNights failed', e); }

        // Ensure reservation and extend forms set hidden balance/amounts just before submission
        document.addEventListener('submit', function (e) {
            try {
                var form = e.target;
                if (!form || !form.id) return;

                // Reservation flow: paymentForm-<id> posts to ReserveRoom and must include Balance = DB + remaining
                if (form.id.indexOf('paymentForm-') === 0) {
                    var bid = form.id.split('-')[1];
                    if (!bid) return;
                    try {
                        var payInput = document.getElementById('payAmountInput-' + bid) || document.getElementById('extendPayAmountInput-' + bid);
                        var entered = parseFloat((payInput && payInput.value) ? payInput.value : '0') || 0;

                        var displayTotalEl = document.getElementById('displayTotal-' + bid);
                        var price = 0;
                        if (displayTotalEl) price = parseFloat((displayTotalEl.textContent || displayTotalEl.innerText || '').replace(/[^0-9.-]+/g, '')) || 0;

                        // remaining owed for this reservation/payment
                        var remaining = Math.max(0, Math.round((price - entered) * 100) / 100);

                        // existing DB balance (from hidden span or hidden input)
                        var existing = 0;
                        var rawExistingEl = document.getElementById('extendBalanceRaw-' + bid);
                        if (rawExistingEl) existing = parseFloat((rawExistingEl.textContent || rawExistingEl.innerText || rawExistingEl.value || '').replace(/[^0-9.-]+/g, '')) || 0;
                        else {
                            var existingInput = document.getElementById('extendExistingBalance-' + bid);
                            if (existingInput) existing = parseFloat((existingInput.value || '').toString().replace(/[^0-9.-]+/g, '')) || 0;
                        }

                        var hiddenBal = document.getElementById('hiddenBalance-' + bid);
                        if (hiddenBal) hiddenBal.value = Math.round((existing + remaining) * 100) / 100;

                        // ensure hidden Total is posted (fallback if confirm modal didn't set it)
                        try {
                            var hiddenTotalInput = document.getElementById('hiddenTotal-' + bid);
                            if (hiddenTotalInput) {
                                var dtEl = document.getElementById('displayTotal-' + bid) || document.getElementById('grandTotalHidden-' + bid);
                                var totalVal = 0;
                                if (dtEl) {
                                    var raw = (dtEl.value || dtEl.textContent || dtEl.innerText || '').toString();
                                    totalVal = parseFloat(raw.replace(/[^0-9.-]+/g, '') || '0') || 0;
                                }
                                // fallback: compute from room rates * stayingDays if available
                                if (!totalVal) {
                                    try {
                                        var rrEl = document.getElementById('roomRates-' + bid);
                                        var sd = parseInt((document.getElementById('extendHiddenNights-' + bid) || { value: '' }).value || '0') || 0;
                                        var rr = 0;
                                        if (rrEl) rr = parseFloat((rrEl.value || rrEl.textContent || rrEl.innerText || '').toString().replace(/[^0-9.-]+/g, '') || '0') || 0;
                                        if (sd > 0) totalVal = Math.round(rr * sd * 100) / 100;
                                    } catch (e) { }
                                }
                                hiddenTotalInput.value = totalVal;
                            }
                        } catch (e) { }

                        var hiddenPaid = document.getElementById('hiddenPaid-' + bid);
                        if (hiddenPaid) hiddenPaid.value = entered;
                        var hiddenChange = document.getElementById('hiddenChange-' + bid);
                        if (hiddenChange) hiddenChange.value = Math.max(0, Math.round((entered - price) * 100) / 100);
                    } catch (err) { console.error('prepare reservation payment submit failed', err); }
                }

                // Extend reservation flow: extendPayForm-<id> posts to ExtendAndPayreserve
                if (form.id.indexOf('extendPayForm-') === 0) {
                    var bid2 = form.id.split('-')[1];
                    if (!bid2) return;
                    try {
                        var input = document.getElementById('extendPayAmountInput-' + bid2) || document.getElementById('payAmountInput-' + bid2);
                        var entered2 = parseFloat((input && input.value) ? input.value : '0') || 0;

                        var hiddenAmt = document.getElementById('extendPayHiddenAmount-' + bid2);
                        if (hiddenAmt) hiddenAmt.value = entered2;
                        var paidForExt = document.getElementById('extendPayHiddenPaidForExtension-' + bid2);
                        if (paidForExt) paidForExt.value = entered2;

                        // calculate addedRemain (extra credit) relative to extendPrice
                        var priceEl = document.getElementById('extendPrice-' + bid2);
                        var priceVal = 0;
                        if (priceEl) priceVal = parseFloat((priceEl.textContent || priceEl.innerText || '').replace(/[^0-9.-]+/g, '')) || 0;
                        var extra = Math.max(0, Math.round((entered2 - priceVal) * 100) / 100);
                        var hiddenAdded = document.getElementById('extendPayHiddenAddedRemain-' + bid2);
                        if (hiddenAdded) hiddenAdded.value = extra;

                        // Compute the "remaining" displayed in the extend-payment modal (unpaid portion)
                        var remaining = Math.max(0, Math.round((priceVal - entered2) * 100) / 100);
                        var hiddenBalanceToAdd = document.getElementById('extendPayHiddenBalanceToAdd-' + bid2);
                        if (hiddenBalanceToAdd) hiddenBalanceToAdd.value = remaining;

                        // ensure existingExtendBalance is normalized to numeric value
                        var existingBalanceInput = document.getElementById('extendExistingBalance-' + bid2);
                        if (existingBalanceInput) {
                            var raw = existingBalanceInput.value || existingBalanceInput.textContent || existingBalanceInput.innerText || '';
                            existingBalanceInput.value = parseFloat((raw || '').toString().replace(/[^0-9.-]+/g, '')) || 0;
                        }
                    } catch (err) { console.error('prepare extend payment submit failed', err); }
                }
            } catch (err) { console.error(err); }
        });

    })();
</script>

<script>
    // When user clicks the Extend "Pay" button, save a client-side payload so
    // the extend success modal can be shown after the server round-trip.
    // This helps ensure the modal has sensible values even if the server
    // response doesn't immediately provide them.
    document.addEventListener('click', function (e) {
        try {
            var el = e.target;
            while (el && el !== document) {
                if (el.tagName === 'BUTTON' && el.id && el.id.indexOf('extendPayNowBtn-') === 0) break;
                el = el.parentNode;
            }
            if (!el || el === document) return;
            var btn = el;
            var idParts = btn.id.split('-');
            var bid = idParts.length > 1 ? idParts[1] : '';
            if (!bid) return;

            // Build a payload with the values that will be shown in the extend
            // success modal. We read hidden fields and visible display elements.
            var getText = function (id) {
                try { var m = document.getElementById(id); return m ? (m.value || m.textContent || m.innerText || '') : ''; } catch (e) { return ''; }
            };

            // Build payload. Compute addedRemain deterministically from visible price and paid values
            // instead of relying solely on a hidden field which may not be populated yet when the
            // button click occurs (the form submit handler populates it later).
            var derivedExtendedPrice = 0;
            try {
                var extPriceEl = document.getElementById('extendPrice-' + bid);
                if (extPriceEl && (extPriceEl.textContent || extPriceEl.innerText)) {
                    derivedExtendedPrice = parseFloat((extPriceEl.textContent || extPriceEl.innerText).toString().replace(/[^0-9.-]+/g, '')) || 0;
                }
                // fallback: compute from room rate * nights
                if (!derivedExtendedPrice) {
                    var rrEl = document.getElementById('extendRoomRate-' + bid);
                    var nnEl = document.getElementById('extendDisplayNights-' + bid) || document.getElementById('extendPayHiddenNights-' + bid);
                    var rateVal = 0;
                    var nightsVal = parseInt((nnEl && (nnEl.value || nnEl.textContent || nnEl.innerText) ? (nnEl.value || nnEl.textContent || nnEl.innerText) : '0').toString().replace(/[^0-9.-]+/g, ''), 10) || 0;
                    if (rrEl && (rrEl.textContent || rrEl.innerText)) rateVal = parseFloat((rrEl.textContent || rrEl.innerText).toString().replace(/[^0-9.-]+/g, '')) || 0;
                    if (rateVal && nightsVal) derivedExtendedPrice = Math.round(rateVal * nightsVal * 100) / 100;
                }
            } catch (e) { derivedExtendedPrice = 0; }

            var derivedPaid = 0;
            try {
                // Prefer the explicit extend payment input to avoid reading values from
                // other payment modals (which can lead to incorrect addedRemain like ₱850).
                var paidCandidates = [
                    'extendPayAmountInput-' + bid,
                    'extendPayHiddenAmount-' + bid,
                    'extendPayHiddenPaidForExtension-' + bid
                ];
                for (var i = 0; i < paidCandidates.length; i++) {
                    try {
                        var pe = document.getElementById(paidCandidates[i]);
                        if (pe && (pe.value || pe.textContent || pe.innerText)) {
                            derivedPaid = parseFloat((pe.value || pe.textContent || pe.innerText).toString().replace(/[^0-9.-]+/g, '')) || 0;
                            if (derivedPaid) break;
                        }
                    } catch (e) { }
                }
            } catch (e) { derivedPaid = 0; }

            // Prefer the displayed Amount Change in the extend-payment modal when present.
            var computedAddedRemain = 0;
            try {
                var changeElDom = document.getElementById('extendChangeDisplayExt-' + bid) || document.getElementById('extendChangeDisplay-' + bid);
                if (changeElDom && (changeElDom.textContent || changeElDom.innerText)) {
                    var parsedChange = parseFloat((changeElDom.textContent || changeElDom.innerText).toString().replace(/[^0-9.-]+/g, '')) || 0;
                    computedAddedRemain = Math.max(0, Math.round(parsedChange * 100) / 100);
                } else {
                    computedAddedRemain = Math.max(0, Math.round((derivedPaid - (derivedExtendedPrice || 0)) * 100) / 100);
                }
            } catch (e) {
                computedAddedRemain = Math.max(0, Math.round((derivedPaid - (derivedExtendedPrice || 0)) * 100) / 100);
            }

            var payload = {
                bookingId: bid,
                newDepartureDate: getText('extendPayHiddenNewDeparture-' + bid) || getText('extendDisplayNewDeparture-' + bid),
                extendedNights: parseInt(getText('extendPayHiddenNights-' + bid) || getText('extendDisplayNights-' + bid) || '0') || 0,
                extendedPrice: derivedExtendedPrice || parseFloat((getText('extendPrice-' + bid) || '').toString().replace(/[^0-9.-]+/g, '')) || 0,
                totalPaid: derivedPaid || parseFloat((getText('extendPayHiddenAmount-' + bid) || getText('extendPayHiddenAmount-' + bid) || '0')) || 0,
                addedRemain: computedAddedRemain || parseFloat((getText('extendPayHiddenAddedRemain-' + bid) || '0')) || 0,
                // prefer the raw stored balance if available
                newBalance: (function () {
                    try {
                        var raw = getText('extendBalanceRaw-' + bid) || getText('extendPayApplied-' + bid) || getText('extendPayAppliedExt-' + bid) || '0';
                        return parseFloat(raw.toString().replace(/[^0-9.-]+/g, '')) || 0;
                    } catch (e) { return 0; }
                })()
            };

            try {
                sessionStorage.setItem('extendSuccessPayload', JSON.stringify(payload));
                console.debug('extendSuccessPayload saved (click):', payload);
            } catch (e) { console.error('store payload on click failed', e); }
            // allow form to submit normally
        } catch (err) { console.error('prepare extend success payload failed', err); }
    });

    // Ensure the extend success payload (saved to sessionStorage by the server flow)
    // will update the page DOM with the authoritative new balance when present.
    document.addEventListener('DOMContentLoaded', function () {
        try {
            var raw = sessionStorage.getItem('extendSuccessPayload');
            if (!raw) return;
            // Remove it early so repeated handlers don't re-run
            try { sessionStorage.removeItem('extendSuccessPayload'); } catch (e) { }

            var payload = null;
            try { payload = JSON.parse(raw); } catch (e) { payload = raw; }
            // In some flows the payload was serialized twice (string containing JSON)
            if (typeof payload === 'string') {
                try { payload = JSON.parse(payload); } catch (e) { /* leave as string */ }
            }
            if (!payload || !payload.bookingId) return;
            var bid = payload.bookingId;

            // If server returned a newBalance, use it. Otherwise try to read any existing hidden span.
            var newBal = null;
            if (typeof payload.newBalance !== 'undefined' && payload.newBalance !== null) {
                newBal = parseFloat(payload.newBalance) || 0;
            }

            // Update the hidden raw balance span so other code reads authoritative value
            try {
                var rawSpan = document.getElementById('extendBalanceRaw-' + bid);
                if (rawSpan) {
                    if (newBal !== null) rawSpan.textContent = newBal.toString();
                }
            } catch (e) { }

            // Update any visible balance elements in the extend success modal / payment UI
            try {
                var formatter = new Intl.NumberFormat('en-PH', { style: 'currency', currency: 'PHP' });

                // Derive canonical numbers from payload or DOM: extendedPrice, paid
                var derivedExtendedPrice = 0;
                try {
                    if (typeof payload.extendedPrice !== 'undefined' && payload.extendedPrice !== null) derivedExtendedPrice = parseFloat(payload.extendedPrice) || 0;
                    else {
                        var extPriceEl = document.getElementById('extendPrice-' + bid);
                        if (extPriceEl) derivedExtendedPrice = parseFloat((extPriceEl.textContent || extPriceEl.innerText || '').replace(/[^0-9.-]+/g, '')) || 0;
                    }

                    // fallback: compute from room rate * nights when extendPrice wasn't set
                    if (!derivedExtendedPrice) {
                        try {
                            var rateEl = document.getElementById('extendRoomRate-' + bid);
                            var nightsEl = document.getElementById('extendDisplayNights-' + bid) || document.getElementById('extendPayHiddenNights-' + bid);
                            var rateVal = 0;
                            var nightsVal = parseInt((payload.extendedNights || 0), 10) || 0;
                            if (rateEl && (rateEl.textContent || rateEl.innerText)) rateVal = parseFloat((rateEl.textContent || rateEl.innerText).toString().replace(/[^0-9.-]+/g, '')) || 0;
                            if (nightsEl && (nightsEl.textContent || nightsEl.innerText || nightsEl.value)) nightsVal = parseInt((nightsEl.value || nightsEl.textContent || nightsEl.innerText).toString().replace(/[^0-9.-]+/g, ''), 10) || nightsVal;
                            if (rateVal && nightsVal) derivedExtendedPrice = Math.round(rateVal * nightsVal * 100) / 100;
                        } catch (ee) { }
                    }
                } catch (e) { derivedExtendedPrice = 0; }

                var derivedPaid = 0;
                try {
                    if (typeof payload.totalPaid !== 'undefined' && payload.totalPaid !== null) derivedPaid = parseFloat(payload.totalPaid) || 0;
                    else if (typeof payload.paidApplied !== 'undefined' && payload.paidApplied !== null) derivedPaid = parseFloat(payload.paidApplied) || 0;
                    else if (typeof payload.paid !== 'undefined' && payload.paid !== null) derivedPaid = parseFloat(payload.paid) || 0;
                    else {
                        // Prefer extend-payment inputs/hidden values; avoid generic pay inputs
                        var hid = document.getElementById('extendPayHiddenAmount-' + bid) || document.getElementById('extendPayHiddenPaidForExtension-' + bid) || document.getElementById('extendPayAmountInput-' + bid);
                        if (hid) derivedPaid = parseFloat((hid.value || hid.textContent || hid.innerText || '').toString().replace(/[^0-9.-]+/g, '')) || 0;
                    }
                } catch (e) { derivedPaid = 0; }

                // remaining unpaid part and added change
                var remainingUnpaid = Math.max(0, Math.round((derivedExtendedPrice - derivedPaid) * 100) / 100);
                var addedChange = Math.max(0, Math.round((derivedPaid - derivedExtendedPrice) * 100) / 100);

                // Update payment modal balance displays (these show remaining unpaid for the extension)
                var appliedEls = [document.getElementById('extendPayApplied-' + bid), document.getElementById('extendPayAppliedExt-' + bid)];
                appliedEls.forEach(function (el) { try { if (el) el.textContent = formatter.format(remainingUnpaid); } catch (e) { } });

                // Update success modal template clones (es-amount = remaining unpaid, es-addedRemain = added change)
                var amtEls = document.querySelectorAll('.es-amount');
                amtEls.forEach(function (a) { try { if (a) a.textContent = formatter.format(remainingUnpaid); } catch (e) { } });
                var addEls = document.querySelectorAll('.es-addedRemain');
                addEls.forEach(function (a) { try { if (a) a.textContent = formatter.format(addedChange); } catch (e) { } });

                // Also update any per-booking visible fields if present
                try {
                    var perAmt = document.getElementById('extendPayApplied-' + bid);
                    if (perAmt) perAmt.textContent = formatter.format(remainingUnpaid);
                    var perChange = document.getElementById('extendChangeDisplayExt-' + bid) || document.getElementById('extendChangeDisplay-' + bid);
                    if (perChange) perChange.textContent = formatter.format(addedChange);
                } catch (e) { }

            } catch (e) { console.error('apply extend success payload display failed', e); }
            } catch (e) { console.error(e); }
        } catch (err) { console.error('apply extend success payload failed', err); }
    });
</script>
