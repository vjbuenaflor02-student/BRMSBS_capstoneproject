    @model IEnumerable<BRMSBS_capstoneproject.Models.ReservationModel>

@{
    ViewData["Title"] = "Reservation List";
    Layout = "~/Views/Layouts/CheckOutReserveLayout.cshtml";

    // Prefer entries where BookReserve indicates a reservation. Accept both "Reservation" and "Reserve"
    var reservationsList = Model != null
        ? Model.Where(b => string.Equals(b.BookReserve, "Reservation", StringComparison.OrdinalIgnoreCase)
                         || string.Equals(b.BookReserve, "Reserved", StringComparison.OrdinalIgnoreCase)).ToList()
        : new List<BRMSBS_capstoneproject.Models.ReservationModel>();

    // Helper to avoid showing default/minimum dates like "1/1/01". If the date is uninitialized (Year <= 1) return empty string.
    var FormatShortDate = new Func<DateTime, string>(dt => (dt.Year <= 1) ? string.Empty : dt.ToString("M/d/yy"));
}

<div class="text-ctr"><b> Manage Reservation List </b></div>

<div class="containerbox">
    @if (reservationsList.Any())
    {
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Action</th>
                    <th>ID</th>
                    <th>Status</th>
                    <th>Room Number</th>
                    <th>Last Name</th>
                    <th>Check-In Date</th>
                    <th>Check-Out Date</th>
                    <th>Balance</th>
                    <th>Access By</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in reservationsList)
                {
                    // mark bookings with status Registered so we can render disabled actions
                    var isReserved = string.Equals(booking.Status, "Reserved", StringComparison.OrdinalIgnoreCase);
                    var isCheckedIn = string.Equals(booking.Status, "Checked-In", StringComparison.OrdinalIgnoreCase);
                    var isPending = string.Equals(booking.Status, "Pending", StringComparison.OrdinalIgnoreCase);

                    // Calculate room rates for data attributes
                    decimal rowRoomRatesDecimal = 0m;
                    decimal.TryParse(Convert.ToString(booking.RoomRates), System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.CurrentCulture, out rowRoomRatesDecimal);
                    if (rowRoomRatesDecimal == 0m)
                    {
                        decimal.TryParse(Convert.ToString(booking.RoomRates), System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out rowRoomRatesDecimal);
                    }

                    <tr data-booking-id="@booking.Id" 
                        data-arrival-date="@(booking.ArrivalDate.Year <= 1 ? string.Empty : booking.ArrivalDate.ToString("yyyy-MM-dd"))"
                        data-departure-date="@(booking.DepartureDate.Year <= 1 ? string.Empty : booking.DepartureDate.ToString("yyyy-MM-dd"))"
                        data-room-type="@booking.RoomType"
                        data-room-number="@booking.RoomNumber"
                        data-room-rates="@rowRoomRatesDecimal"
                        data-number-of-pax="@booking.NumberOfPax"
                        data-guest-names="@booking.GuestNames"
                        data-extend-balance="@booking.ExtendBalance">
                        <td>
                            @* Enable Check-In button for all non-checked-in reservations *@
                                   @if (isCheckedIn)
                            {
                                <button type="button" class="btn btn-outline-primary btn-sm disabled" disabled="disabled" aria-disabled="true">Check-In</button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-outline-primary btn-sm quick-checkin-btn" data-booking-id="@booking.Id" data-arrival-date="@(booking.ArrivalDate.Year <= 1 ? string.Empty : booking.ArrivalDate.ToString("yyyy-MM-dd"))">Check-In</button>
                            }

                            @if (!isReserved && !isPending)
                            {
                                <button type="button" class="btn btn-outline-success btn-sm checkout-open-btn" data-bs-toggle="modal" data-bs-target="#checkoutPriceModal-@booking.Id">Check Out</button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-outline-success btn-sm checkout-open-btn disabled" disabled="disabled" aria-disabled="true">Check Out</button>
                            }
                            @if (!isReserved && !isPending)
                            {
                                <button type="button" class="btn btn-outline-primary btn-sm extend-stay-btn" data-booking-id="@booking.Id">Extend</button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-outline-primary btn-sm disabled" disabled="disabled" aria-disabled="true">Extend</button>
                            }

                            <button type="button" class="btn btn-outline-info btn-sm" data-bs-toggle="modal" data-bs-target="#infoModal-@booking.Id">Info</button>
                        </td>
                        <td>@booking.Id</td>
                        <td><span id="status-@booking.Id">@booking.Status</span></td>
                        <td>@booking.RoomNumber</td>
                        <td>@booking.LastName</td>
                        <td>@(booking.ArrivalDate.Year <= 1 ? string.Empty : booking.ArrivalDate.ToString("M/d/yy"))</td>
                        <td>@(booking.DepartureDate.Year <= 1 ? string.Empty : booking.DepartureDate.ToString("M/d/yy"))</td>
                        <td>@booking.ExtendBalance</td>
                        <td>@booking.AccessBy</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="text-center text-muted">No reservations found.</div>
    }
</div>


