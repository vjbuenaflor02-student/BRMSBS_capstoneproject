                var checkin = (checkinEl && checkinEl.value) ? checkinEl.value : '';
                var checkout = (checkoutEl && checkoutEl.value) ? checkoutEl.value : '';
                var roomNumber = (roomNumEl && roomNumEl.value) ? roomNumEl.value : '';
                var roomType = (roomTypeEl && roomTypeEl.value) ? roomTypeEl.value : '';
                var roomRatesText = (roomRatesEl && roomRatesEl.value) ? roomRatesEl.value : (roomRatesEl && roomRatesEl.textContent ? roomRatesEl.textContent : '0');
                var pax = (paxEl && paxEl.value) ? paxEl.value : '';
                var guestNames = (guestNamesEl && (guestNamesEl.value || guestNamesEl.textContent)) ? (guestNamesEl.value || guestNamesEl.textContent) : '';
                if (!guestNames || !guestNames.toString().trim()) guestNames = 'n/a';

                var rateNum = parseFloat((roomRatesText || '').toString().replace(/[^0-9.-]+/g, '')) || 0;

                var d1 = parseDateOnlyLocal(checkin);
