@model IEnumerable<BRMSBS_capstoneproject.Models.ReservationModel>

@{
    ViewData["Title"] = "Reservation List";
    Layout = "~/Views/Layouts/CheckOutReserveLayout.cshtml";

    // Prefer entries where BookReserve indicates a reservation. Accept both "Reservation" and "Reserve"
    var reservationsList = Model != null
        ? Model.Where(b => string.Equals(b.BookReserve, "Reservation", StringComparison.OrdinalIgnoreCase)
                         || string.Equals(b.BookReserve, "Reserved", StringComparison.OrdinalIgnoreCase)).ToList()
        : new List<BRMSBS_capstoneproject.Models.ReservationModel>();

    // Helper to avoid showing default/minimum dates like "1/1/01". If the date is uninitialized (Year <= 1) return empty string.
    var FormatShortDate = new Func<DateTime, string>(dt => (dt.Year <= 1) ? string.Empty : dt.ToString("M/d/yy"));
    // Helper that returns ISO date (yyyy-MM-dd) for <input type="date" value="..."> or empty string when date is uninitialized
    var FormatIsoDate = new Func<DateTime, string>(dt => (dt.Year <= 1) ? string.Empty : dt.ToString("yyyy-MM-dd"));
}


@if (TempData["ReserveSuccess"] != null)
{
    <div class="modal fade" id="reserveSuccessModal" tabindex="-1" aria-labelledby="reserveSuccessModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="reserveSuccessModalLabel">Reservation Successful</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-start">
                    Your reservation has been successfully added.
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        window.addEventListener('DOMContentLoaded', function () {
            try {
                var m = document.getElementById('reserveSuccessModal');
                if (m) {
                    var inst = new bootstrap.Modal(m);
                    inst.show();
                }
            } catch (e) { console.error(e); }
        });

        // Server-side TempData debug entries removed from client output to reduce noise.
    </script>
}

<div class="text-ctr"><b> Manage Reservation List </b></div>

<div class="containerbox">
    @if (reservationsList.Any())
    {
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Action</th>
                    <th>ID</th>
                    <th>Status</th>
                    <th>Room Number</th>
                    <th>Last Name</th>
                    <th>Check-In Date</th>
                    <th>Check-Out Date</th>
                    <th>ExtendBalance</th>
                    <th>Access By</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in reservationsList)
                {
                    // mark bookings with status Registered so we can render disabled actions
                    var isRegistered = string.Equals(booking.Status, "Registered", StringComparison.OrdinalIgnoreCase);
                    var isReserved = string.Equals(booking.Status, "Reserved", StringComparison.OrdinalIgnoreCase);
                <tr data-booking-id="@booking.Id">
                        <td>
                            @* Disable Check-In when the booking status is Reserved *@
                            @if (!isReserved)
                            {
                                <button type="button" class="btn btn-outline-primary btn-sm open-checkin-btn" data-booking-id="@booking.Id" data-bs-toggle="modal" data-bs-target="#checkinModal-@booking.Id">Check-In</button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-outline-primary btn-sm open-checkin-btn disabled" disabled="disabled" aria-disabled="true" data-reserved="1">Check-In</button>
                            }
                            
                            @if (!isRegistered)
                            {
                                <button type="button" class="btn btn-outline-success btn-sm checkout-open-btn" data-bs-toggle="modal" data-bs-target="#checkoutPriceModal-@booking.Id">Check Out</button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-outline-success btn-sm checkout-open-btn disabled" disabled="disabled" aria-disabled="true">Check Out</button>
                            }

                            @if (!isRegistered)
                            {
                                <button type="button" class="btn btn-outline-success btn-sm extend-stay-btn" data-booking-id="@booking.Id">Extend</button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-outline-success btn-sm extend-stay-btn disabled" disabled="disabled" aria-disabled="true">Extend</button>
                            }

                            @* Show a compact "mini" info modal for bookings marked as Registered; otherwise show the full info modal *@
                            @if (isRegistered)
                            {
                                <button type="button" class="btn btn-outline-info btn-sm" data-bs-toggle="modal" data-bs-target="#miniInfoModal-@booking.Id">Info</button>
                            }
                            else
                            {
                                // For Reserved (check-in) and all other statuses show full info modal
                                <button type="button" class="btn btn-outline-info btn-sm" data-bs-toggle="modal" data-bs-target="#infoModal-@booking.Id">Info</button>
                            }
                        </td>
                        <td>@booking.Id</td>
                        <td><span id="status-@booking.Id">@booking.Status</span></td>
                        <td>@booking.RoomNumber</td>
                        <td>@booking.LastName</td>
                        <td>@(booking.ArrivalDate.Year <= 1 ? string.Empty : booking.ArrivalDate.ToString("M/d/yy"))</td>
                        <td>@(booking.DepartureDate.Year <= 1 ? string.Empty : booking.DepartureDate.ToString("M/d/yy"))</td>
                        <td>@booking.ExtendBalance</td>
                        <td>@booking.AccessBy</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="text-center text-muted">No reservations found.</div>
    }
</div>

<!-- Check Out Price Modal -->
@foreach (var booking in reservationsList)
{
    // Check-In Modal: shows room information and allows operator to confirm check-in
    <div class="modal fade" id="checkinModal-@booking.Id" tabindex="-1" aria-labelledby="checkinModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="checkinModalLabel-@booking.Id">Room Information - Check In (@booking.Id)</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Check-In Date</label>
                            @* Use stored arrival date when present, otherwise default to today. Disable past dates but allow future selections. *@
                            @{
                                // Block the next 2 days for check-in; earliest selectable check-in is today + 2
                                var earliestCheckin = DateTime.Today.AddDays(2);
                                var initialCheckin = (booking.ArrivalDate.Date >= earliestCheckin) ? booking.ArrivalDate : earliestCheckin;
                            }
                            <input type="date" class="form-control checkin-date" id="checkinDate-@booking.Id" value="@initialCheckin.ToString("yyyy-MM-dd")" min="@earliestCheckin.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Check-out Date</label>
                            @* By default require check-in first; checkout min will be set to (checkin + 1) via JS. Also prevent selecting past dates. *@
                            <input type="date" class="form-control checkout-date" id="checkoutDate-@booking.Id" value="@FormatIsoDate(booking.DepartureDate)" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Room Type</label>
                            <select class="form-select room-type-select" id="roomTypeSelect-@booking.Id">
                                <option value="">-- Select here --</option>
                                <option value="Standard">Standard</option>
                                <option value="Deluxe">Deluxe</option>
                                <option value="Premium">Premium</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Room Number</label>
                            <select class="form-select room-number-select" id="roomNumberSelect-@booking.Id" @(String.IsNullOrEmpty(booking.RoomNumber) ? "disabled" : "")>
                                <option value="">-- Select Room Type First --</option>
                                @if (!string.IsNullOrEmpty(booking.RoomNumber)) { <option value="@booking.RoomNumber" selected>@booking.RoomNumber</option> }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Room Rates (Price)</label>
                            @{ decimal rr = 0m; decimal.TryParse(Convert.ToString(booking.RoomRates), out rr); }
                            <input type="text" class="form-control room-rates" id="roomRates-@booking.Id" value="@rr.ToString("C0", new System.Globalization.CultureInfo("en-PH"))" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Number of Pax (Capacity)</label>
                            <input type="text" class="form-control pax-capacity" id="pax-@booking.Id" value="@booking.NumberOfPax" readonly />
                        </div>

                        <div class="col-12">
                            <label class="form-label">Guest Names</label>
                            <input type="text" class="form-control" id="guestNames-@booking.Id" value="@booking.GuestNames" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <form asp-action="CheckIn" asp-controller="System" method="post" class="m-0 p-0" id="checkinForm-@booking.Id">
                        <input type="hidden" name="bookingId" value="@booking.Id" />
                        <input type="hidden" name="selectedRoomNumber" id="formRoomNumber-@booking.Id" />
                        <input type="hidden" name="selectedCheckoutDate" id="formCheckoutDate-@booking.Id" />
                        <button type="submit" class="btn btn-primary">Proceed to Check-In</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Confirm Room Details Modal (shown when Proceed to Check-In clicked) -->
    <div class="modal fade" id="confirmCheckinModal-@booking.Id" tabindex="-1" aria-labelledby="confirmCheckinModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmCheckinModalLabel-@booking.Id">Confirm Room Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <table class="table table-sm">
                        <tbody>
                            <tr><th>Check-in Date</th><td id="confirmCheckinDate-@booking.Id"></td></tr>
                            <tr><th>Check-out Date</th><td id="confirmCheckoutDate-@booking.Id"></td></tr>
                            <tr><th>Room Number</th><td id="confirmRoomNumber-@booking.Id"></td></tr>
                            <tr><th>Room Type</th><td id="confirmRoomType-@booking.Id"></td></tr>
                            <tr><th>Room Rates</th><td id="confirmRoomRates-@booking.Id"></td></tr> 
                            <tr><th>Number of Pax</th><td id="confirmPax-@booking.Id"></td></tr>
                            <tr><th>Total Amount</th><td id="confirmTotal-@booking.Id"></td></tr>
                            <tr><th>Guest Names</th><td id="confirmGuestNames-@booking.Id"></td></tr>
                        </tbody>
                    </table>
                    <div>Do you want to confirm this reservation?</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary confirm-checkin-btn" data-booking-id="@booking.Id">Reserve Now</button>
                </div>
            </div>
        </div>
    </div>
    // Safely parse RoomRates which may be null/empty or non-numeric in some records.
    decimal roomRatesDecimal = 0m;
    // Try current culture first, then invariant as a fallback
    decimal.TryParse(Convert.ToString(booking.RoomRates), System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.CurrentCulture, out roomRatesDecimal);
    if (roomRatesDecimal == 0m)
    {
        decimal.TryParse(Convert.ToString(booking.RoomRates), System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out roomRatesDecimal);
    }
    var stayingDays = (booking.DepartureDate - booking.ArrivalDate).Days; 
    var total = stayingDays * roomRatesDecimal;
    <span id="extendExtendBalanceRaw-@booking.Id" style="display:none">@booking.ExtendBalance</span>
    <div class="modal fade" id="checkoutPriceModal-@booking.Id" tabindex="-1" aria-labelledby="checkoutPriceModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="checkoutPriceModalLabel-@booking.Id">Check Out Reservation</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <dl class="row">
                        <dt class="col-sm-3">Booking ID</dt>
                        <dd class="col-sm-9">@booking.Id</dd>
                        <dt class="col-sm-3">First Name</dt>
                        <dd class="col-sm-9">@booking.FirstName</dd>
                        <dt class="col-sm-3">Last Name</dt>
                        <dd class="col-sm-9">@booking.LastName</dd>
                        <dt class="col-sm-3">Book/Reserve</dt>
                        <dd class="col-sm-9">@booking.BookReserve</dd>
                        <dt class="col-sm-3">Check-In Date</dt>
                        <dd class="col-sm-9">@(booking.ArrivalDate.Year <= 1 ? string.Empty : booking.ArrivalDate.ToString("yyyy-MM-dd"))</dd>
                        <dt class="col-sm-3">Check-Out Date</dt>
                        <dd class="col-sm-9">@(booking.DepartureDate.Year <= 1 ? string.Empty : booking.DepartureDate.ToString("yyyy-MM-dd"))</dd>
                        <dt class="col-sm-3">Room Number</dt>
                        <dd class="col-sm-9">@booking.RoomNumber</dd>
                        <dt class="col-sm-3">Room Type</dt>
                        <dd class="col-sm-9">@booking.RoomType</dd>
                        <dt class="col-sm-3">Paid Booking</dt>
                        <dd class="col-sm-9"><b>@booking.PaidReserve.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</b></dd>
                    </dl class="row">
                    ----------------------------------------------------------
                    <dl class="row">
                        <dt class="col-sm-5">Number of Pax</dt>
                        <dd class="col-sm-7">@booking.NumberOfPax.ToString()</dd>
                        <dt class="col-sm-5">Room Rates</dt>
                        <dd class="col-sm-7">@roomRatesDecimal.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</dd>
                        <dt class="col-sm-5">Staying Days</dt>
                        <dd class="col-sm-7">@stayingDays.ToString() nights</dd>
                        <dt class="col-sm-5">Extend ExtendBalance</dt>
                        <dd class="col-sm-7"><b>@booking.ExtendBalance.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</b></dd>
                    </dl>

                    Do you want to check out this selected booking/reservaton?<br/>
                    This action cannot be undone.
                </div>
                <div class="modal-footer">
                    <!-- remove automatic BS toggles and use class + data attribute for JS control -->
                    <button type="button" class="btn btn-success open-payment-btn" data-booking-id="@booking.Id" data-book-reserve="@booking.BookReserve">Check Out Now</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Check-In Payment Modal (for reservation/checkin flows) -->
    <div class="modal fade" id="checkinPaymentModal-@booking.Id" tabindex="-1" aria-labelledby="checkinPaymentModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="checkinPaymentModalLabel-@booking.Id">Check In Payment - Reservation @booking.Id</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @{ 
                        // For check-in (reservation) payment modal reuse reservation layout
                        decimal initialTotalForDisplayCheckin = Convert.ToDecimal(total);
                        try {
                            var rawBalObj = booking.ExtendBalance;
                            double parsedBal = 0;
                            if (rawBalObj != null) double.TryParse(Convert.ToString(rawBalObj), out parsedBal);
                            if (parsedBal > 0) {
                                initialTotalForDisplayCheckin = Convert.ToDecimal(parsedBal);
                            }
                        } catch { }
                    }

                    <div class="mb-2">Total Amount: <strong id="displayTotal-@booking.Id">@initialTotalForDisplayCheckin.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</strong></div>
                    
                    <div class="mb-3" id="payAmountContainer-@booking.Id">
                        <label for="checkinPayAmountInput-@booking.Id" class="form-label">Enter Pay Amount</label>
                        <input type="number" step="0.01" min="0" class="form-control" id="checkinPayAmountInput-@booking.Id" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label"> Amount Balance</label>
                        <div id="extendPayApplied-@booking.Id" class="fw-bold">@(0.ToString("C2", new System.Globalization.CultureInfo("en-PH")))</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Amount Change</label>
                        <div id="extendChangeDisplay-@booking.Id" class="fw-bold">@(0.ToString("C2", new System.Globalization.CultureInfo("en-PH")))</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <!-- Reservation flow: submit updated reservation values -->
                    <form asp-action="ReserveRoom" asp-controller="System" method="post" id="paymentForm-@booking.Id">
                        <input type="hidden" name="Id" value="@booking.Id" />
                        <input type="hidden" name="ArrivalDate" id="hiddenArrival-@booking.Id" />
                        <input type="hidden" name="DepartureDate" id="hiddenDeparture-@booking.Id" />
                        <input type="hidden" name="RoomType" id="hiddenRoomType-@booking.Id" />
                        <input type="hidden" name="RoomNumber" id="hiddenRoomNumber-@booking.Id" />
                        <input type="hidden" name="RoomRates" id="hiddenRoomRates-@booking.Id" />
                        <input type="hidden" name="NumberOfPax" id="hiddenPax-@booking.Id" />
                        <input type="hidden" name="GuestNames" id="hiddenGuestNames-@booking.Id" />
                        <input type="hidden" name="Total" id="hiddenTotal-@booking.Id" />
                        <input type="hidden" name="ExtendBalance" id="hiddenExtendBalance-@booking.Id" />
                        <input type="hidden" name="ChangeReserve" id="hiddenChange-@booking.Id" />
                        <input type="hidden" name="PaidReserve" id="hiddenPaid-@booking.Id" />
                        <button type="submit" class="btn btn-success" id="extendPayNowBtn-@booking.Id">Pay</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Check-Out Payment Modal (for checkout flows) -->
    <div class="modal fade" id="checkoutPaymentModal-@booking.Id" tabindex="-1" aria-labelledby="checkoutPaymentModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="checkoutPaymentModalLabel-@booking.Id">Payment Check Out - Reservation @booking.Id</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @{
                        decimal initialTotalForDisplayCheckout = Convert.ToDecimal(total);
                        try
                        {
                            var rawBalObj = booking.ExtendBalance;
                            double parsedBal = 0;
                            if (rawBalObj != null) double.TryParse(Convert.ToString(rawBalObj), out parsedBal);
                            if (parsedBal > 0)
                            {
                                initialTotalForDisplayCheckout = Convert.ToDecimal(parsedBal);
                            }
                        }
                        catch { }
                    }

                    <div class="mb-2">Total Amount: <strong id="displayTotal-@booking.Id">@initialTotalForDisplayCheckout.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</strong></div>

                    <div class="mb-3" id="payAmountContainer-@booking.Id">
                        <label for="checkoutPayAmountInput-@booking.Id" class="form-label">Enter Pay Amount</label>
                        <input type="number" step="0.01" min="0" class="form-control" id="checkoutPayAmountInput-@booking.Id" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Amount Change</label>
                        <div id="extendChangeDisplay-@booking.Id" class="fw-bold">@(0.ToString("C2", new System.Globalization.CultureInfo("en-PH")))</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <!-- Booking flow: checkout form -->
                    <form asp-action="CheckOut" asp-controller="System" method="post" id="checkoutPaymentForm-@booking.Id">
                        <input type="hidden" name="bookingId" value="@booking.Id" />
                        <input type="hidden" name="stayingDays" value="@stayingDays" />
                        <input type="hidden" name="grandTotal" value="@initialTotalForDisplayCheckout" id="grandTotalHidden-@booking.Id" />
                        <input type="hidden" name="payAmount" id="extendPayHiddenAmount-@booking.Id" />
                        <input type="hidden" name="addedRemain" id="extendPayHiddenAddedRemain-@booking.Id" />
                        <input type="hidden" name="ExtendBalanceToAdd" id="extendPayHiddenExtendBalanceToAdd-@booking.Id" />
                        <input type="hidden" name="existingExtendExtendBalance" id="extendExistingExtendBalance-@booking.Id" value="@booking.ExtendBalance" />
                        <input type="hidden" name="paidForExtension" id="extendPayHiddenPaidForExtension-@booking.Id" />
                        <!-- Pay button intentionally disabled and non-submitting for checkout flow (reserved for later use) -->
                        <button type="button" class="btn btn-success" disabled="disabled" aria-disabled="true">Pay</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Direct checkout form for bookings (hidden). This uses booking's stored cash values so payment modal is skipped for Bookings -->
    <form asp-action="CheckOut" asp-controller="System" asp-route-bookingId="@booking.Id" method="post" id="directCheckoutForm-@booking.Id" style="display:none;">
        <input type="hidden" name="stayingDays" value="@stayingDays" />
        <input type="hidden" name="grandTotal" value="@total" />
    </form>

    <!-- Extend Stay Modal -->
    <div class="modal fade" id="extendStayModal-@booking.Id" tabindex="-1" aria-labelledby="extendStayModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="extendStayModalLabel-@booking.Id">Extend Stay - Booking @booking.Id</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label"><strong>Original Check-Out Date</strong></label>
                        <div>@(booking.DepartureDate.Year <= 1 ? string.Empty : booking.DepartureDate.ToString("yyyy-MM-dd"))</div>
                    </div>
                    <div class="mb-3">
                        <label for="extendNewCheckoutDate-@booking.Id" class="form-label">Choose new Check-Out Date</label>
                        <input type="date" class="form-control extend-new-checkout-date" id="extendNewCheckoutDate-@booking.Id" data-original-checkout="@(booking.DepartureDate.Year <= 1 ? string.Empty : booking.DepartureDate.ToString("yyyy-MM-dd"))" />
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold">Extended Nights</label><div id="extendNightsDisplay-@booking.Id">0</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary extend-now-btn" data-booking-id="@booking.Id">Extend Now</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Extend Payment Modal -->
    <div class="modal fade" id="extendPaymentModal-@booking.Id" tabindex="-1" aria-labelledby="extendPaymentModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="extendPaymentModalLabel-@booking.Id">Extend Payment - Booking @booking.Id</h5>
