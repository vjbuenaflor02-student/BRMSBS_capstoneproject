                } catch (e) { }
                try {
                    var hiddenChange = document.getElementById('hiddenChange-' + bookingId);
                    if (hiddenChange) hiddenChange.value = change;
                } catch (e) { }
            } catch (err) { console.error(err); }
        });

        // compute extended nights for extend modal
        // More robust parsing: accept ISO (yyyy-MM-dd) and common localized formats.
        function computeExtendedNights(bookingId) {
            var newDep = document.getElementById('newDeparture-' + bookingId);
            var origDepEl = document.getElementById('originalDeparture-' + bookingId);
            var extendedEl = document.getElementById('extendedNights-' + bookingId);
            var hiddenNew = document.getElementById('extendHiddenNewDeparture-' + bookingId);
            var hiddenNights = document.getElementById('extendHiddenNights-' + bookingId);
            var btn = document.getElementById('extendNowBtn-' + bookingId);

            if (!newDep || !origDepEl || !extendedEl || !hiddenNew || !hiddenNights || !btn) return;

            // helper: try parsing yyyy-MM-dd first, then mm/dd/yyyy, then Date constructor
            var parseAnyDate = function (v) {
                if (!v) return null;
                v = (v || '').toString().trim();
                // try yyyy-MM-dd
                var d = parseDateOnlyLocal(v); // defined earlier in this script
                if (d) return d;
                // try mm/dd/yyyy or m/d/yyyy
                var m = v.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
                if (m) {
                    var mo = parseInt(m[1], 10) - 1;
                    var da = parseInt(m[2], 10);
                    var yr = parseInt(m[3], 10);
                    return new Date(yr, mo, da, 0, 0, 0, 0);
                }
                // fallback to Date
                var fallback = new Date(v);
                return isNaN(fallback.getTime()) ? null : fallback;
            };

            var origText = (origDepEl.textContent || origDepEl.innerText || '').trim();
            var orig = parseAnyDate(origText);
            var chosen = parseAnyDate(newDep.value || newDep.getAttribute('value') || '');

            if (!orig || !chosen || isNaN(chosen.getTime()) || chosen <= orig) {
                extendedEl.textContent = '0';
                hiddenNights.value = 0;
                hiddenNew.value = '';
                btn.disabled = true;
                return;
            }

            var diffMs = chosen - orig;
            var nights = Math.floor(diffMs / (1000 * 60 * 60 * 24));
            if (nights < 1) nights = 0;
            extendedEl.textContent = nights.toString();
            hiddenNights.value = nights;
            hiddenNew.value = newDep.value;
            btn.disabled = nights === 0;
        }

        // Delegated listeners: run computeExtendedNights when the new-departure input changes
