<!-- Extend success modal and TempData-driven client display removed to avoid unused/duplicated client-side success flows. Server-side processing remains unchanged. -->

<!-- Centralized JS: hide checkout modal then show payment modal; handle payment input and validation -->
<script>
    (function () {
        var currencyFormatter = new Intl.NumberFormat('en-PH', { style: 'currency', currency: 'PHP', currencyDisplay: 'narrowSymbol', maximumFractionDigits: 2 });

        // Parse a date-only string in yyyy-MM-dd as local midnight, or fall back to Date parsing.
        function parseDateOnlyLocal(value) {
            if (!value) return null;
            var m = value.match(/^(\d{4})-(\d{2})-(\d{2})$/);
            if (m) {
                var y = parseInt(m[1], 10);
                var mo = parseInt(m[2], 10) - 1;
                var d = parseInt(m[3], 10);
                return new Date(y, mo, d, 0, 0, 0, 0);
            }
            var parsed = new Date(value);
            return isNaN(parsed.getTime()) ? null : parsed;
        }

        // Enable/disable Check Out buttons based on arrival date.
        function refreshCheckoutButtons() {
            try {
                var btns = document.querySelectorAll('.checkout-open-btn');
                if (!btns || btns.length === 0) return;
                // use full current timestamp so button enables at the exact arrival datetime
                var nowMs = Date.now();
                btns.forEach(function (btn) {
                    try {
                        // If server marked this booking as Registered, keep checkout disabled regardless of arrival date
                        try {
                            if (btn.getAttribute && btn.getAttribute('data-registered') === '1') {
                                btn.disabled = true;
                                btn.setAttribute('disabled', '');
                                btn.classList.add('disabled');
                                btn.setAttribute('aria-disabled', 'true');
                                return;
                            }
                        } catch (e) { }
                        // prefer server-provided UTC ms to avoid timezone issues
                        var arrivalMsAttr = btn.getAttribute('data-arrival-ms');
                        var arrMs = null;
                        if (arrivalMsAttr) {
                            var parsedMs = parseInt(arrivalMsAttr, 10);
                            if (!isNaN(parsedMs)) arrMs = parsedMs;
                        }

                        if (arrMs === null) {
                            var arrival = btn.getAttribute('data-arrival');
                            if (!arrival) return;
                            var arrDate = parseDateOnlyLocal(arrival);
                            if (!arrDate) return;
                            arrMs = arrDate.getTime();
                        }

                        if (nowMs >= arrMs) {
                            // enable
                            btn.disabled = false;
                            btn.removeAttribute('disabled');
                            btn.classList.remove('disabled');
                            btn.setAttribute('aria-disabled', 'false');
                        } else {
                            // disable
                            btn.disabled = true;
                            btn.setAttribute('disabled', '');
                            btn.classList.add('disabled');
                            btn.setAttribute('aria-disabled', 'true');
                        }
                    } catch (e) { console.error(e); }
                });
            } catch (e) { console.error(e); }
        }

        // run on load and periodically to catch date changes while page is open
        try { document.addEventListener('DOMContentLoaded', refreshCheckoutButtons); } catch (e) { }
        try { setInterval(refreshCheckoutButtons, 30000); } catch (e) { }

        // Enable/disable Check-In buttons based on arrival date
        function refreshCheckInButtons() {
            try {
                var btns = document.querySelectorAll('.quick-checkin-btn');
                if (!btns || btns.length === 0) return;
                var nowMs = Date.now();
                btns.forEach(function (btn) {
                    try {
                        // Get arrival date from data attribute
                        var arrival = btn.getAttribute('data-arrival-date');
                        if (!arrival) return;
                        var arrDate = parseDateOnlyLocal(arrival);
                        if (!arrDate) return;
                        var arrMs = arrDate.getTime();

                        if (nowMs >= arrMs) {
                            // enable - arrival date is today or in the past
                            btn.disabled = false;
                            btn.removeAttribute('disabled');
                            btn.classList.remove('disabled');
                            btn.setAttribute('aria-disabled', 'false');
                        } else {
                            // disable - arrival date is in the future
                            btn.disabled = true;
                            btn.setAttribute('disabled', '');
                            btn.classList.add('disabled');
                            btn.setAttribute('aria-disabled', 'true');
                        }
                    } catch (e) { console.error(e); }
                });
            } catch (e) { console.error(e); }
        }

        // run on load and periodically to catch date changes while page is open
        try { document.addEventListener('DOMContentLoaded', refreshCheckInButtons); } catch (e) { }
        try { setInterval(refreshCheckInButtons, 30000); } catch (e) { }

        // Server-side authoritative ExtendBalances map (keyed by booking id string) so client can read DB value
        var serverExtendBalances = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((Model ?? new List<BRMSBS_capstoneproject.Models.ReservationModel>()).ToDictionary(b => b.Id.ToString(), b => b.ExtendBalance)));

        function formatCurrencyPH(value) {
            try {
                return new Intl.NumberFormat('en-PH', { style: 'currency', currency: 'PHP' }).format(Number(value) || 0);
            } catch (e) {
                return '₱' + (Number(value) || 0).toFixed(2);
            }
        }

        function findRoom(roomNumber) {
            if (!rooms || !roomNumber) return null;
            return (rooms || []).find(function (r) { return String(r.RoomNumber) === String(roomNumber); }) || null;
        }

        function populateRoomNumbersForBooking(bookingId, roomType) {
            var selectId = 'roomNumberSelect-' + bookingId;
            var sel = document.getElementById(selectId);
            if (!sel) return;
            // clear
            sel.innerHTML = '';
            if (!roomType) {
                sel.innerHTML = '<option value="">-- Select Room Type First --</option>';
                sel.disabled = true;
                return;
            }

            var available = (rooms || []).filter(function (r) { return (r.Status === 'Available' || r.Status === 'available') && String(r.RoomType) === String(roomType); });
            if (available.length > 0) {
                sel.disabled = false;
                sel.innerHTML = '<option value="">-- Select Room here --</option>';
                available.forEach(function (r) {
                    var opt = document.createElement('option');
                    opt.value = r.RoomNumber;
                    opt.text = r.RoomNumber;
                    sel.appendChild(opt);
                });
                // if only one, auto-select like BookingA
                if (sel.options.length === 2) {
                    sel.selectedIndex = 1;
                    sel.dispatchEvent(new Event('change', { bubbles: true }));
                }
            } else {
                sel.innerHTML = '<option value="">No Available</option>';
                sel.disabled = true;
            }
        }

        // Delegated change handler for per-booking room selects
        document.addEventListener('change', function (e) {
            try {
                var rt = e.target.closest && e.target.closest('.room-type-select');
                if (rt) {
                    var parts = rt.id.split('-');
                    var bid = parts.length > 1 ? parts[1] : '';
                    var type = rt.value;
                    populateRoomNumbersForBooking(bid, type);
                    return;
                }

                var rn = e.target.closest && e.target.closest('.room-number-select');
                if (rn) {
                    var parts2 = rn.id.split('-');
                    var bid2 = parts2.length > 1 ? parts2[1] : '';
                    var selected = rn.value;
                    var ratesEl = document.getElementById('roomRates-' + bid2);
                    var paxEl = document.getElementById('pax-' + bid2);
                    var formRoomHidden = document.getElementById('formRoomNumber-' + bid2);
                    if (!selected) {
                        if (ratesEl) ratesEl.value = formatCurrencyPH(0);
                        if (paxEl) paxEl.value = '';
                        if (formRoomHidden) formRoomHidden.value = '';
                        return;
                    }
                    var room = findRoom(selected);
                    if (!room) return;
                    var price = Number(room.RoomPrice || room.RoomRates || room.RoomRate || 0);
                    if (ratesEl) ratesEl.value = formatCurrencyPH(price);
                    if (paxEl) {
                        paxEl.value = room.RoomCapacity || room.NumberOfPax || '';
                        try { paxEl.max = room.RoomCapacity || room.NumberOfPax || ''; } catch (e) {}
                    }
                    if (formRoomHidden) formRoomHidden.value = selected;
                }
            } catch (ex) { console.error(ex); }
        });

        // Open payment modal after hiding price modal, or directly submit for Bookings
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.open-payment-btn');
            if (!btn) return;

            var bookingId = btn.getAttribute('data-booking-id');
            if (!bookingId) return;

            var bookReserve = (btn.getAttribute('data-book-reserve') || '').toLowerCase();

            var checkoutEl = document.getElementById('checkoutPriceModal-' + bookingId);
            var paymentEl = document.getElementById('checkoutPaymentModal-' + bookingId);

            // Hide checkout price modal if open
            try {
                var checkoutInstance = bootstrap.Modal.getInstance(checkoutEl);
                if (!checkoutInstance) checkoutInstance = bootstrap.Modal.getOrCreateInstance(checkoutEl);
                checkoutInstance.hide();
            } catch (err) {
                // ignore
            }

            // If this is a Booking (not a Reservation), decide based on extend ExtendBalance:
            if (bookReserve === 'booking') {
                var directForm = document.getElementById('directCheckoutForm-' + bookingId);

                // read raw extend ExtendBalance (rendered server side in hidden span)
                var rawBalEl = document.getElementById('extendExtendBalanceRaw-' + bookingId);
                var ExtendBalance = 0;
                try {
                    if (rawBalEl) {
                        var txt = (rawBalEl.textContent || rawBalEl.innerText || rawBalEl.value || '0').toString();
                        // strip non-numeric chars if any
                        var cleaned = txt.replace(/[^0-9.-]+/g, '');
                        ExtendBalance = parseFloat(cleaned || '0') || 0;
                    }
                } catch (ex) { ExtendBalance = 0; }

                // If there's an extend ExtendBalance > 0, show payment modal so user can pay it.
                if (ExtendBalance > 0) {
                    try {
                        var paymentInstance = bootstrap.Modal.getOrCreateInstance(paymentEl);

                        // set displayTotal and hidden grand total to the extend ExtendBalance (so validation uses correct total)
                        var displayTotalEl = document.getElementById('displayTotal-' + bookingId);
                        var grandHiddenEl = document.getElementById('grandTotalHidden-' + bookingId);
                        if (displayTotalEl) displayTotalEl.textContent = currencyFormatter.format(ExtendBalance);
                        if (grandHiddenEl) grandHiddenEl.value = ExtendBalance;

                        paymentInstance.show();

                        // small delay to allow modal DOM to be active
                        setTimeout(function () {
                            var cashInput = document.getElementById('cashAmount-' + bookingId);
                            if (cashInput) {
                                cashInput.focus();
                                updateChangeFor(bookingId);
                            }
                        }, 120);
                    } catch (err) {
                        console.error(err);
                    }

                    return;
                }

                // Otherwise no extend ExtendBalance => submit direct checkout (server will set TempData and show success modal on reload)
                if (directForm) {
                    directForm.submit();
                    return;
                }
            }

            // Otherwise for Reservation, check if ExtendBalance is 0
            // If ExtendBalance is 0, directly submit checkout without payment modal
            // Otherwise show payment modal
            var rawBalEl = document.getElementById('extendExtendBalanceRaw-' + bookingId);
            var reservationExtendBalance = 0;
            try {
                if (rawBalEl) {
                    var txt = (rawBalEl.textContent || rawBalEl.innerText || rawBalEl.value || '0').toString();
                    var cleaned = txt.replace(/[^0-9.-]+/g, '');
                    reservationExtendBalance = parseFloat(cleaned || '0') || 0;
                }
            } catch (ex) { reservationExtendBalance = 0; }

            if (reservationExtendBalance === 0) {
                // No extend balance - directly submit checkout form
                var checkoutPayForm = document.getElementById('checkoutPaymentForm-' + bookingId);
                if (checkoutPayForm) {
                    // Set hidden fields to zero since no payment needed
                    try {
                        var cashAmountInput = checkoutPayForm.querySelector('[name="cashAmount"]');
                        var cashChangeInput = checkoutPayForm.querySelector('[name="cashChange"]');
                        if (cashAmountInput) cashAmountInput.value = 0;
                        if (cashChangeInput) cashChangeInput.value = 0;
                    } catch (e) { }

                    checkoutPayForm.submit();
                    return;
                }
            }

            // ExtendBalance > 0, show payment modal
            try {
                var paymentInstance = bootstrap.Modal.getOrCreateInstance(paymentEl);
                paymentInstance.show();

                // small delay to allow modal DOM to be active
                setTimeout(function () {
                    var cashInput = document.getElementById('checkoutPayAmountInput-' + bookingId);
                    if (cashInput) {
                        cashInput.focus();
                        updateChangeFor(bookingId);
                    }
                }, 120);
            } catch (err) {
                console.error(err);
            }
        });

        // Delegated handler to open info modal: click on the Info button
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.open-checkin-btn');
            if (!btn) return;
            // Respect disabled state rendered by server: do nothing if button is disabled
            try {
                if (btn.disabled || btn.getAttribute && btn.getAttribute('aria-disabled') === 'true') return;
            } catch (ex) { }
            e.preventDefault();
            var bookingId = btn.getAttribute('data-booking-id');
            if (!bookingId) return;
            var checkinEl = document.getElementById('checkinModal-' + bookingId);
            if (!checkinEl) return;
            try {
                var instance = bootstrap.Modal.getOrCreateInstance(checkinEl);
                instance.show();
            } catch (err) {
                console.error(err);
            }
        });

        // Hide extend success modal if present before showing payment modal
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.open-payment-btn');
            if (!btn) return;
            var bookingId = btn.getAttribute('data-booking-id');
            if (!bookingId) return;

            // Hide any open extend success modal for this booking (closes by id prefix)
            try {
                var openExtSuccess = document.querySelector("[id^='extendSuccessModal_temp_" + bookingId + "']");
                if (openExtSuccess) {
                    var inst = bootstrap.Modal.getInstance(openExtSuccess);
                    if (inst) inst.hide();
                }
            } catch (e) { }
        });

        // When typing pay amount update hidden field
        document.addEventListener('input', function (e) {
            var target = e.target;
            if (!target || !target.id) return;

            // accept pay input from either checkout or extend-payment modals (check-in modal removed)
            var isCheckoutInput = target.id.startsWith('checkoutPayAmountInput-');
            var isExtendInput = target.id.startsWith('extendPayAmountInput-');

            if (!(isCheckoutInput || isExtendInput)) return;

            // Extract booking ID
            var bookingId = target.id.substring(target.id.lastIndexOf('-') + 1);
            var enteredValue = parseFloat(target.value || '0') || 0;

            // Get total price / balance based on which modal is active
            var totalPrice = 0;

            if (isCheckoutInput) {
                // For checkout modal - use checkoutGrandTotalHidden first
                var checkoutGrandEl = document.getElementById('checkoutGrandTotalHidden-' + bookingId);
                if (checkoutGrandEl && checkoutGrandEl.value) {
                    totalPrice = parseFloat(checkoutGrandEl.value) || 0;
                }
                // Fallback to checkoutDisplayTotal text content
                if (!totalPrice) {
                    var checkoutDisplayEl = document.getElementById('checkoutDisplayTotal-' + bookingId);
                    if (checkoutDisplayEl) {
                        var displayText = (checkoutDisplayEl.textContent || checkoutDisplayEl.innerText || '').toString();
                        totalPrice = parseFloat(displayText.replace(/[^0-9.-]+/g, '')) || 0;
                    }
                }
            } else {
                // For extend payment modal
                var extendedPriceEl = document.getElementById('extendPayExtendedPrice-' + bookingId);
                if (extendedPriceEl) {
                    var extendedPriceText = extendedPriceEl.textContent || '';
                    totalPrice = parseFloat(extendedPriceText.replace(/[^0-9.-]+/g, '')) || 0;
                }
            }

            // Fallback: try extendExtendBalanceRaw
            if (!totalPrice) {
                var rawBalEl = document.getElementById('extendExtendBalanceRaw-' + bookingId);
                if (rawBalEl) {
                    var rawVal = (rawBalEl.textContent || rawBalEl.innerText || '').toString();
                    totalPrice = parseFloat(rawVal.replace(/[^0-9.-]+/g, '')) || 0;
                }
            }

            // Normalize values
            if (isNaN(totalPrice)) totalPrice = 0;
            if (isNaN(enteredValue)) enteredValue = 0;

            var totalRounded = Math.round(totalPrice * 100) / 100;
            var enteredRounded = Math.round(enteredValue * 100) / 100;

            // Logic for checkout and extend modals
            var change = Math.max(0, Math.round((enteredRounded - totalRounded) * 100) / 100);
            var remaining = Math.max(0, Math.round((totalRounded - enteredRounded) * 100) / 100);

            // Update Amount Change display
            var changeEl = isCheckoutInput 
                ? document.getElementById('checkoutChangeDisplay-' + bookingId)
                : document.getElementById('extendPayChangeDisplay-' + bookingId);

            if (changeEl) {
                changeEl.textContent = currencyFormatter.format(change);
            }

            // Update remaining/balance display if present
            var balanceEl = isCheckoutInput 
                ? null 
                : document.getElementById('extendPayBalanceDisplay-' + bookingId);
            if (balanceEl) {
                balanceEl.textContent = currencyFormatter.format(remaining);
            }

            // Update hidden fields for form submission
            try {
                if (isCheckoutInput) {
                    var checkoutPayHiddenChange = document.getElementById('checkoutPayHiddenChange-' + bookingId);
                    var checkoutPayHiddenAmount = document.getElementById('checkoutPayHiddenAmount-' + bookingId);
                    if (checkoutPayHiddenChange) checkoutPayHiddenChange.value = change;
                    if (checkoutPayHiddenAmount) checkoutPayHiddenAmount.value = enteredValue;
                } else {
                    var extendHiddenPayAmount = document.getElementById('extendHiddenPayAmount-' + bookingId);
                    var extendHiddenBalance = document.getElementById('extendHiddenExtendBalance-' + bookingId);
                    var extendHiddenChange = document.getElementById('extendHiddenChangeAmount-' + bookingId);
                    if (extendHiddenPayAmount) extendHiddenPayAmount.value = enteredValue;
                    if (extendHiddenBalance) extendHiddenBalance.value = remaining;
                    if (extendHiddenChange) extendHiddenChange.value = change;
                }
            } catch (e) { }

            // Enable/disable Pay button
            var shouldEnable = false;
            var payBtn = null;

            if (isCheckoutInput) {
                payBtn = document.getElementById('checkoutPayBtn-' + bookingId);
                // For checkout: enable if entered amount >= total amount
                shouldEnable = enteredValue > 0 && enteredRounded >= totalRounded;
            } else {
                // For extend modal
                payBtn = document.getElementById('extendPayBtn-' + bookingId);
                // For extend: user must pay at least 750 or full amount if less than 750
                var minToEnable = totalRounded <= 750 ? totalRounded : 750;
                shouldEnable = enteredValue >= minToEnable;
            }

            if (payBtn) {
                payBtn.disabled = !shouldEnable;
                payBtn.setAttribute('aria-disabled', (!shouldEnable).toString());
            }
        });

        // compute extended nights for extend modal
        // More robust parsing: accept ISO (yyyy-MM-dd) and common localized formats.
        function computeExtendedNights(bookingId) {
            // Extended nights computation removed
        }

        // When check-in date changes, set checkout min to (checkin + 1) and default the checkout value
        document.addEventListener('change', function (e) {
            try {
                var cd = e.target && e.target.classList && e.target.classList.contains('checkin-date') ? e.target : (e.target.closest && e.target.closest('.checkin-date'));
                if (!cd) return;

                var parts = (cd.id || '').split('-');
                var bid = parts.length > 1 ? parts[1] : '';
                var checkoutEl = document.getElementById('checkoutDate-' + bid);
                if (!checkoutEl) return;

                var av = (cd.value || '').toString();
                var arrDate = parseDateOnlyLocal(av);
                if (!arrDate) {
                    // no valid arrival -> disable checkout
                    checkoutEl.disabled = true;
                    checkoutEl.setAttribute('disabled', '');
                    return;
                }

                // compute min (checkin + 1)
                var minDate = new Date(arrDate.getFullYear(), arrDate.getMonth(), arrDate.getDate() + 1);
                var minY = minDate.getFullYear();
                var minM = String(minDate.getMonth() + 1).padStart(2, '0');
                var minD = String(minDate.getDate()).padStart(2, '0');
                var minStr = minY + '-' + minM + '-' + minD;

                checkoutEl.min = minStr;

                // if current value is missing or earlier than min, set it to min
                var cur = (checkoutEl.value || '').toString();
                var curDate = parseDateOnlyLocal(cur);
                if (!curDate || (arrDate && curDate.getTime() <= arrDate.getTime())) {
                    try { checkoutEl.value = minStr; } catch (e) { }
                }

                // enable checkout
                checkoutEl.disabled = false;
                checkoutEl.removeAttribute('disabled');
            } catch (ex) { console.error(ex); }
        });

        // Initialize checkout inputs based on any pre-filled checkin dates on load
        document.addEventListener('DOMContentLoaded', function () {
            try {
                var cds = document.querySelectorAll('.checkin-date');
                cds.forEach(function (cd) {
                    try { cd.dispatchEvent(new Event('change', { bubbles: true })); } catch (e) { }
                });
            } catch (e) { }
        });

        // Disable all payment submit buttons by default
        document.addEventListener('DOMContentLoaded', function () {
            try {
                // Disable all pay buttons initially
                var payBtns = document.querySelectorAll('[id$="PayNowBtn"], [id$="PayBtn"], [id$="checkoutPayBtn"], [id$="extendPayBtn"]');
                payBtns.forEach(function (btn) {
                    try {
                        btn.disabled = true;
                        btn.setAttribute('aria-disabled', 'true');
                    } catch (e) { }
                });
            } catch (e) { }
        });

        // When user clicks "Check In Now" on confirm modal, directly submit check-in without payment modal.
        // Status will be set to "Checked-In" and success modal will be shown.
        document.addEventListener('click', function (e) {
            try {
                var btn = e.target.closest && e.target.closest('.confirm-checkin-btn');
                if (!btn) return;
                e.preventDefault();
                e.stopPropagation();
                var bookingId = btn.getAttribute('data-booking-id');
                if (!bookingId) return;

                var confirmEl = document.getElementById('confirmCheckinModal-' + bookingId);
                var checkinForm = document.getElementById('directCheckinForm-' + bookingId);

                if (!checkinForm) {
                    console.error('Check-in form not found for booking ID:', bookingId);
                    alert('Error: Check-in form not found. Please try again.');
                    return;
                }

                // Hide confirm modal
                try {
                    if (confirmEl) {
                        var cm = bootstrap.Modal.getInstance(confirmEl) || bootstrap.Modal.getOrCreateInstance(confirmEl);
                        if (cm) cm.hide();
                    }
                } catch (ex) { }

                // Submit the check-in form directly
                checkinForm.submit();
            } catch (e) { console.error(e); }
        });

        // Expose computeExtendedNights to global scope so delegated handlers defined
        // outside this IIFE can call it (some handlers are added in separate <script> blocks).
        try {
            if (typeof window !== 'undefined' && typeof computeExtendedNights === 'function') {
                window.computeExtendedNights = computeExtendedNights;
            }
        } catch (e) { console.error('expose computeExtendedNights failed', e); }

        // Extend Stay button handler - open extend stay modal
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.extend-stay-btn');
            if (!btn) return;

            var bookingId = btn.getAttribute('data-booking-id');
            if (!bookingId) {
                console.error('Extend button: no booking ID found');
                return;
            }

            var extendStayEl = document.getElementById('extendStayModal-' + bookingId);
            if (!extendStayEl) {
                console.error('Extend modal not found for booking ID:', bookingId);
                alert('Error: Extend modal not found. Please try again.');
                return;
            }

            try {
                var instance = bootstrap.Modal.getOrCreateInstance(extendStayEl);
                instance.show();

                // Set min date and default value for new checkout date input
                var dateInput = document.getElementById('extendNewCheckoutDate-' + bookingId);
                if (dateInput) {
                    // Get original departure date from the data attribute
                    var originalCheckout = dateInput.getAttribute('data-original-checkout');

                    if (originalCheckout) {
                        // Set minimum to original checkout + 1 day (for at least 1 night extension)
                        var origDate = parseDateOnlyLocal(originalCheckout);
                        if (origDate) {
                            var minDate = new Date(origDate.getFullYear(), origDate.getMonth(), origDate.getDate() + 1);
                            var minY = minDate.getFullYear();
                            var minMo = String(minDate.getMonth() + 1).padStart(2, '0');
                            var minD = String(minDate.getDate()).padStart(2, '0');
                            dateInput.min = minY + '-' + minMo + '-' + minD;

                            // Set default value to original checkout + 1 day
                            dateInput.value = minY + '-' + minMo + '-' + minD;

                            // Trigger change event to update extended nights display
                            dateInput.dispatchEvent(new Event('change', { bubbles: true }));
                        }
                    }
                }
            } catch (err) {
                console.error('Error opening extend stay modal:', err);
                alert('Error opening extend modal. Please try again.');
            }
        });

        // Extend new checkout date change - calculate extended nights
        document.addEventListener('change', function (e) {
            var dateInput = e.target.closest('.extend-new-checkout-date');
            if (!dateInput) return;

            var bookingId = dateInput.id.split('-')[1];
            if (!bookingId) return;

            var newCheckoutDateStr = dateInput.value;
            var nightsDisplay = document.getElementById('extendNightsDisplay-' + bookingId);

            if (!newCheckoutDateStr) {
                if (nightsDisplay) nightsDisplay.textContent = '0';
                return;
            }

            // Get original departure date from the data attribute (ISO format: yyyy-MM-dd)
            var originalCheckoutStr = dateInput.getAttribute('data-original-checkout');

            if (originalCheckoutStr) {
                var originalDate = parseDateOnlyLocal(originalCheckoutStr);
                var newDate = parseDateOnlyLocal(newCheckoutDateStr);

                if (originalDate && newDate) {
                    // Calculate extended nights: difference between new date and original date
                    var extendedNights = Math.max(0, Math.floor((newDate - originalDate) / (1000 * 60 * 60 * 24)));
                    if (nightsDisplay) nightsDisplay.textContent = extendedNights;
                }
            }
        });

        // Extend Now button - open extend payment modal with calculated values
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.extend-now-btn');
            if (!btn) return;

            var bookingId = btn.getAttribute('data-booking-id');
            if (!bookingId) return;

            var extendStayEl = document.getElementById('extendStayModal-' + bookingId);
            var extendPaymentEl = document.getElementById('extendPaymentModal-' + bookingId);
            var dateInput = document.getElementById('extendNewCheckoutDate-' + bookingId);
            var nightsDisplay = document.getElementById('extendNightsDisplay-' + bookingId);

            if (!dateInput || !dateInput.value) {
                alert('Please select a new check-out date.');
                return;
            }

            var newCheckoutDate = dateInput.value;
            var extendedNights = parseInt((nightsDisplay && nightsDisplay.textContent) || '0');

            if (extendedNights <= 0) {
                alert('Extended nights must be greater than 0.');
                return;
            }

            // Get room rate - try multiple sources
            var roomRate = 0;

            // First try: check-in modal room rates field
            try {
                var checkinRatesEl = document.getElementById('roomRates-' + bookingId);
                if (checkinRatesEl && (checkinRatesEl.value || checkinRatesEl.textContent)) {
                    var rateText = checkinRatesEl.value || checkinRatesEl.textContent || '';
                    roomRate = parseFloat(rateText.replace(/[^0-9.-]+/g, '')) || 0;
                }
            } catch (err) { }

            // Second try: info modal - look for room rates in room information section
            if (roomRate === 0) {
                try {
                    var infoModal = document.getElementById('infoModal-' + bookingId);
                    if (infoModal) {
                        var dlElements = infoModal.querySelectorAll('dt');
                        for (var i = 0; i < dlElements.length; i++) {
                            var dt = dlElements[i];
                            if (dt.textContent.includes('Room Rates')) {
                                var dd = dt.nextElementSibling;
                                if (dd) {
                                    var rateText = dd.textContent || '';
                                    roomRate = parseFloat(rateText.replace(/[^0-9.-]+/g, '')) || 0;
                                    break;
                                }
                            }
                        }
                    }
                } catch (err) { }
            }

            // Fallback: try to calculate from stored room data if available
            if (roomRate === 0) {
                try {
                    var rowEl = document.querySelector('tr[data-booking-id="' + bookingId + '"]');
                    if (rowEl) {
                        // Room rate might be available from an info button click
                        var infoBtn = rowEl.querySelector('[data-bs-target^="#infoModal-"]');
                        if (infoBtn) {
                            // Trigger info modal to populate data
                            infoBtn.click();
                            // Try again after a small delay
                            setTimeout(function() {
                                try {
                                    var infoModal = document.getElementById('infoModal-' + bookingId);
                                    if (infoModal) {
                                        var dlElements = infoModal.querySelectorAll('dt');
                                        for (var j = 0; j < dlElements.length; j++) {
                                            var dt = dlElements[j];
                                            if (dt.textContent.includes('Room Rates')) {
                                                var dd = dt.nextElementSibling;
                                                if (dd) {
                                                    var rateText = dd.textContent || '';
                                                    roomRate = parseFloat(rateText.replace(/[^0-9.-]+/g, '')) || 0;
                                                    break;
                                                }
                                            }
                                        }
                                    }
                                } catch (err) { }
                            }, 100);
                        }
                    }
                } catch (err) { }
            }

            if (roomRate === 0) {
                alert('Unable to determine room rate. Please check the room information.');
                return;
            }

            // Calculate extended price
            var extendedPrice = Math.round((roomRate * extendedNights) * 100) / 100;

            // Populate extend payment modal
            try {
                var setText = function (id, val) {
                    try { var el = document.getElementById(id + '-' + bookingId); if (el) el.textContent = val; } catch (e) { }
                };
                var setHiddenValue = function (id, val) {
                    try { var el = document.getElementById(id + '-' + bookingId); if (el) el.value = val; } catch (e) { }
                };

                setText('extendPayNewCheckoutDate', newCheckoutDate);
                setText('extendPayRoomRate', formatCurrencyPH(roomRate));
                setText('extendPayExtendedNights', extendedNights + ' night' + (extendedNights > 1 ? 's' : ''));
                setText('extendPayExtendedPrice', formatCurrencyPH(extendedPrice));

                setHiddenValue('extendHiddenNewCheckoutDate', newCheckoutDate);
                setHiddenValue('extendHiddenExtendedNights', extendedNights);
                setHiddenValue('extendHiddenExtendedPrice', extendedPrice);

                // Reset pay amount input and displays
                var payInput = document.getElementById('extendPayAmountInput-' + bookingId);
                if (payInput) {
                    payInput.value = '';
                    // Explicitly set initial balance and change displays to 0 (before user enters amount)
                    var balanceDisplay = document.getElementById('extendPayBalanceDisplay-' + bookingId);
                    var changeDisplay = document.getElementById('extendPayChangeDisplay-' + bookingId);
                    if (balanceDisplay) balanceDisplay.textContent = currencyFormatter.format(0);
                    if (changeDisplay) changeDisplay.textContent = currencyFormatter.format(0);
                    // Note: dispatchEvent omitted since we're setting displays directly to zero
                }
            } catch (err) {
                console.error('Error populating extend payment modal:', err);
                alert('Error preparing payment modal. Please try again.');
                return;
            }

            // Hide extend stay modal and show extend payment modal
            try {
                if (extendStayEl) {
                    var stayInstance = bootstrap.Modal.getInstance(extendStayEl);
                    if (stayInstance) stayInstance.hide();
                }
            } catch (ex) { }

            if (extendPaymentEl) {
                try {
                    var paymentInstance = bootstrap.Modal.getOrCreateInstance(extendPaymentEl);
                    paymentInstance.show();
                    setTimeout(function () {
                        var payInput = document.getElementById('extendPayAmountInput-' + bookingId);
                        if (payInput) payInput.focus();
                    }, 120);
                } catch (err) {
                    console.error('Error showing extend payment modal:', err);
                    alert('Error opening payment modal. Please try again.');
                }
            }
        });

        // Extend payment amount input handler
        document.addEventListener('input', function (e) {
            var target = e.target;
            if (!target) return;

            if (!(target.id && target.id.startsWith('extendPayAmountInput-'))) return;

            var bookingId = target.id.split('-')[1];
            var extendedPriceEl = document.getElementById('extendPayExtendedPrice-' + bookingId);
            var balanceDisplay = document.getElementById('extendPayBalanceDisplay-' + bookingId);
            var changeDisplay = document.getElementById('extendPayChangeDisplay-' + bookingId);
            var payBtn = document.getElementById('extendPayBtn-' + bookingId);

            if (!extendedPriceEl) return;

            var extendedPriceText = extendedPriceEl.textContent || '';
            var extendedPrice = parseFloat(extendedPriceText.replace(/[^0-9.-]+/g, '')) || 0;

            var enteredAmount = parseFloat(target.value || '0') || 0;

            var balance = Math.max(0, Math.round((extendedPrice - enteredAmount) * 100) / 100);
            var change = Math.max(0, Math.round((enteredAmount - extendedPrice) * 100) / 100);

            // Update displays
            try { if (balanceDisplay) balanceDisplay.textContent = currencyFormatter.format(balance); } catch (err) { }
            try { if (changeDisplay) changeDisplay.textContent = currencyFormatter.format(change); } catch (err) { }

            // Update hidden fields
            try {
                var hiddenPayAmount = document.getElementById('extendHiddenPayAmount-' + bookingId);
                var hiddenBalance = document.getElementById('extendHiddenExtendBalance-' + bookingId);
                var hiddenChange = document.getElementById('extendHiddenChangeAmount-' + bookingId);

                if (hiddenPayAmount) hiddenPayAmount.value = enteredAmount;
                if (hiddenBalance) hiddenBalance.value = balance;
                if (hiddenChange) hiddenChange.value = change;
            } catch (err) { }

            // Enable/disable pay button - extend payment has a 750 minimum threshold
            try {
                // For extend: user must pay at least 750 or full amount if less than 750
                var minToEnable = extendedPrice <= 750 ? extendedPrice : 750;
                var shouldEnable = enteredAmount >= minToEnable;
                if (payBtn) {
                    payBtn.disabled = !shouldEnable;
                    payBtn.setAttribute('aria-disabled', (!shouldEnable).toString());
                    console.log('Extend button update - Min:', minToEnable, 'Entered:', enteredAmount, 'Enabled:', shouldEnable);
                }
            } catch (err) { 
                console.error('Extend button enable logic error:', err);
            }
        });

        // Quick Check-In button handler - opens confirmation modal directly
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.quick-checkin-btn');
            if (!btn) return;

            var bookingId = btn.getAttribute('data-booking-id');
            if (!bookingId) return;

            // Show the confirmation modal directly
            try {
                var confirmModal = document.getElementById('confirmCheckinModal-' + bookingId);
                if (confirmModal) {
                    var instance = bootstrap.Modal.getOrCreateInstance(confirmModal);
                    instance.show();
                }
            } catch (err) {
                console.error('Error opening check-in confirmation modal:', err);
            }
        });

    })();
</script>
