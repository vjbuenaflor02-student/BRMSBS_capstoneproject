        window.addEventListener('DOMContentLoaded', function () {
            // Ensure bootstrap is available before instantiating modal (avoid ReferenceError)
            (function showSuccess(attemptsLeft) {
                try {
                    if (typeof bootstrap === 'undefined' || !bootstrap.Modal) {
                        if (attemptsLeft <= 0) { console.error('bootstrap not available to show successModal'); return; }
                        setTimeout(function () { showSuccess(attemptsLeft - 1); }, 200);
                        return;
                    }
                    var successModal = new bootstrap.Modal(document.getElementById('successModal'));
                    successModal.show();
                } catch (e) { console.error('show success modal failed', e); }
            })(15);
        });

        // (Initialization moved to the rooms IIFE so it runs after helper functions are defined)
        

        // Note: extend modal is shown by Bootstrap via data-bs attributes on the button
    </script>
    
}

