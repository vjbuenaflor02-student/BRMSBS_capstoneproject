    <script>
        window.addEventListener('DOMContentLoaded', function () {
            // Ensure bootstrap is available before instantiating modal (avoid ReferenceError)
            (function showExtendSuccess(attemptsLeft) {
                try {
                    if (typeof bootstrap === 'undefined' || !bootstrap.Modal) {
                        if (attemptsLeft <= 0) { console.error('bootstrap not available to show extendSuccessModal'); return; }
                        setTimeout(function () { showExtendSuccess(attemptsLeft - 1); }, 200);
                        return;
                    }
                    var extendSuccessModal = new bootstrap.Modal(document.getElementById('extendSuccessModal'));
                    extendSuccessModal.show();
                } catch (e) { console.error('show extend success modal failed', e); }
            })(15);
        });
    </script>
