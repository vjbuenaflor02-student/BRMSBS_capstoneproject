@if (TempData["ExtendSuccessPayload"] != null)
{
    <script>
        (function () {
            try {
                // Read the server TempData string safely into a JS string literal
                var serverPayloadString = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Convert.ToString(TempData["ExtendSuccessPayload"])));

                var payload = null;
                try {
                    // First, parse the serialized JSON string provided by server
                    payload = JSON.parse(serverPayloadString);
                } catch (ex) {
                    try {
                        // Some flows may double-serialize; try parsing twice
                        payload = JSON.parse(JSON.parse(serverPayloadString));
                    } catch (ex2) {
                        console.error('Failed to parse ExtendSuccessPayload from TempData', ex, ex2, serverPayloadString);
                        payload = null;
                    }
                }

                if (!payload) return;

                // Build and show the extend success modal directly (avoid sessionStorage)
                try {
                    // Ensure any reload-saved payload does not also attempt to show a modal
                    try { sessionStorage.removeItem('extendSuccessPayload'); sessionStorage.setItem('extendSuccessPayloadShown', '1'); } catch (e) { }
                    var template = document.getElementById('extendSuccessModal');
                    if (!template) return;
                    var clone = template.cloneNode(true);
                    var unique = 'es_temp_' + ((payload && payload.bookingId) ? payload.bookingId + '_' : '') + new Date().getTime();
                    clone.id = 'extendSuccessModal_temp_' + unique;
                    clone.style.display = '';
                    clone.style.zIndex = 20000;

                    var bEl = clone.querySelector('.es-bookingId');
                    var ndEl = clone.querySelector('.es-newDate');
                    var nEl = clone.querySelector('.es-nights');
                    var amtEl = clone.querySelector('.es-amount');
                    var tdEl = clone.querySelector('.es-totalDays');
                    var tsEl = clone.querySelector('.es-totalSpent');
                    var dateEl = clone.querySelector('.es-changeDate');

                    if (bEl) bEl.textContent = payload.bookingId || '';
                    if (ndEl) ndEl.textContent = payload.newDepartureDate || '';
                    if (nEl) nEl.textContent = (payload.extendedNights || '') + '';

                    try {
                        var arrivalEl = document.getElementById('arrivalDate-' + (payload.bookingId || ''));
                        if (arrivalEl && arrivalEl.textContent && tdEl) {
                            var arrival = new Date(arrivalEl.textContent + 'T00:00:00');
                            var newDep = new Date((payload.newDepartureDate || '') + 'T00:00:00');
                            if (!isNaN(arrival.getTime()) && !isNaN(newDep.getTime())) {
                                var diffMs = newDep - arrival;
                                var days = Math.floor(diffMs / (1000 * 60 * 60 * 24));
                                tdEl.textContent = (days > 0 ? days : 0).toString();
                            }
                        }
                    } catch (e) { console.error(e); }

                    try {
                        var displayAmount2 = 0;
                        if (typeof payload.paid !== 'undefined' && payload.paid !== null) displayAmount2 = payload.paid;
                        else if (typeof payload.paidApplied !== 'undefined' && payload.paidApplied !== null) displayAmount2 = payload.paidApplied;
                        else if (typeof payload.totalPaid !== 'undefined' && payload.totalPaid !== null) displayAmount2 = payload.totalPaid;

                        // Prefer authoritative balance read from the database in this order:
                        // 1) serverBalances map (serialized from server Model for this reload),
                        // 2) the hidden raw DOM element `extendBalanceRaw-<id>` rendered by server,
                        // 3) payload.newBalance returned by the server in TempData, and
                        // 4) fall back to the payment-derived value (displayAmount2).
                        var chosenBalance = null;
                        try {
                            if (typeof serverBalances !== 'undefined' && serverBalances) {
                                var sb = serverBalances[(payload.bookingId || '').toString()];
                                if (typeof sb !== 'undefined' && sb !== null) {
                                    // Accept zero as a valid DB value
                                    chosenBalance = parseFloat(sb) || 0;
                                }
                            }
                        } catch (e) { }

                        if (chosenBalance === null) {
                            try {
                                var rawDom = document.getElementById('extendBalanceRaw-' + (payload.bookingId || ''));
                                if (rawDom) {
                                    var raw = (rawDom.textContent || rawDom.innerText || rawDom.value || '').replace(/[^0-9.-]+/g, '');
                                    chosenBalance = parseFloat(raw || '0') || 0;
                                }
                            } catch (e) { }
                        }

                        if (chosenBalance === null) {
                            if (typeof payload.newBalance !== 'undefined' && payload.newBalance !== null) {
                                chosenBalance = parseFloat(payload.newBalance) || 0;
                            }
                        }

                        if (amtEl) {
                            try {
                                // Deterministic: compute price and paid from payload first, then DOM fallbacks.
                                var priceNum = 0;
                                var paidNum = 0;

                                // Price: payload > extendPrice element > roomRate * nights
                                try {
                                    if (typeof payload.extendedPrice !== 'undefined' && payload.extendedPrice !== null) priceNum = parseFloat(payload.extendedPrice) || 0;
                                } catch (e) { }
                                if (!priceNum) {
                                    try {
                                        var ep = document.getElementById('extendPrice-' + (payload.bookingId || ''));
                                        if (ep && (ep.textContent || ep.innerText)) priceNum = parseFloat((ep.textContent || ep.innerText).toString().replace(/[^0-9.-]+/g, '')) || 0;
                                    } catch (e) { }
                                }
                                if (!priceNum) {
                                    try {
                                        var rr = document.getElementById('extendRoomRate-' + (payload.bookingId || ''));
                                        var nn = document.getElementById('extendDisplayNights-' + (payload.bookingId || '')) || { textContent: (payload.extendedNights || 0) };
                                        var rate = rr && (rr.textContent || rr.innerText) ? parseFloat((rr.textContent || rr.innerText).toString().replace(/[^0-9.-]+/g, '')) || 0 : 0;
