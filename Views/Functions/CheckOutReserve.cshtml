        // No payment option radios: user must enter pay amount

        // when typing pay amount update hidden field
        document.addEventListener('input', function (e) {
            var target = e.target;
            if (!target) return;
            // accept pay input from either the general payment modal or the extend-payment modal
            if (!(target.id && (target.id.startsWith('payAmountInput-') || target.id.startsWith('extendPayAmountInput-')))) return;

