@model IEnumerable<BRMSBS_capstoneproject.Models.ReservationModel>

@{
    ViewData["Title"] = "Reservation List";
    Layout = "~/Views/Layouts/CheckOutReserveLayout.cshtml";

    // Prefer entries where BookReserve indicates a reservation. Accept both "Reservation" and "Reserve"
    var reservationsList = Model != null
        ? Model.Where(b => string.Equals(b.BookReserve, "Reservation", StringComparison.OrdinalIgnoreCase)
                         || string.Equals(b.BookReserve, "Reserved", StringComparison.OrdinalIgnoreCase)).ToList()
        : new List<BRMSBS_capstoneproject.Models.ReservationModel>();

    // Helper to avoid showing default/minimum dates like "1/1/01". If the date is uninitialized (Year <= 1) return empty string.
    var FormatShortDate = new Func<DateTime, string>(dt => (dt.Year <= 1) ? string.Empty : dt.ToString("M/d/yy"));
    // Helper that returns ISO date (yyyy-MM-dd) for <input type="date" value="..."> or empty string when date is uninitialized
    var FormatIsoDate = new Func<DateTime, string>(dt => (dt.Year <= 1) ? string.Empty : dt.ToString("yyyy-MM-dd"));
}


@if (TempData["ReserveSuccess"] != null)
{
    <div class="modal fade" id="reserveSuccessModal" tabindex="-1" aria-labelledby="reserveSuccessModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="reserveSuccessModalLabel">Reservation Successful</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-start">
                    Your reservation has been successfully added.
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        window.addEventListener('DOMContentLoaded', function () {
            try {
                var m = document.getElementById('reserveSuccessModal');
                if (m) {
                    var inst = new bootstrap.Modal(m);
                    inst.show();
                }
            } catch (e) { console.error(e); }
        });

    // Also capture form submissions (only when submitted by clicking the Pay button).
    // We intentionally IGNORE implicit submits (like pressing Enter in the pay input)
    // because those can occur before client JS populates hidden fields and lead to
    // stale payloads (showing incorrect amount change).
    document.addEventListener('submit', function (e) {
        try {
            var form = e.target;
            if (!form || !form.id) return;

            // Only proceed when the submit was triggered by clicking a visible Pay button.
            // Browsers set `e.submitter` to the element that initiated the submit when
            // available. If no submitter (implicit Enter key), bail out.
            try {
                var submitter = e.submitter || null;
                if (!submitter || !(submitter.tagName === 'BUTTON' && submitter.id && submitter.id.indexOf('extendPayNowBtn-') === 0)) {
                    return; // do not save payload for implicit submits
                }
            } catch (ex) {
                // If submitter isn't supported or an error occurs, be conservative and bail.
                return;
            }

            var bid = null;
            if (form.id.indexOf('extendPayForm-') === 0) {
                bid = form.id.split('-')[1];
            } else if (form.id.indexOf('paymentForm-') === 0) {
                // paymentForm may also be used for reservation-pay flows which can
                // represent an extension when hidden extend fields are present.
                var possible = form.querySelector('[name="bookingId"]') || form.querySelector('[id^="extendPayHiddenNights-"]');
                if (possible) {
                    // try to read booking id from input[name=bookingId] or from id of form
                    var bInput = form.querySelector('[name="bookingId"]');
                    if (bInput && bInput.value) bid = bInput.value;
                    else bid = form.id.split('-')[1];
                }
            }
            if (!bid) return;

            var getText = function (id) {
                try { var m = document.getElementById(id); return m ? (m.value || m.textContent || m.innerText || '') : ''; } catch (e) { return ''; }
            };

            // Compute values deterministically here as hidden fields may not yet be populated
            var derivedExtendedPrice = 0;
            try {
                var epEl = document.getElementById('extendPrice-' + bid);
                if (epEl && (epEl.textContent || epEl.innerText)) derivedExtendedPrice = parseFloat((epEl.textContent || epEl.innerText).toString().replace(/[^0-9.-]+/g, '')) || 0;
                if (!derivedExtendedPrice) {
                    var rr = document.getElementById('extendRoomRate-' + bid);
                    var nn = document.getElementById('extendDisplayNights-' + bid) || document.getElementById('extendPayHiddenNights-' + bid);
                    var rateV = 0;
                    var nightsV = parseInt((nn && (nn.value || nn.textContent || nn.innerText) ? (nn.value || nn.textContent || nn.innerText) : '0').toString().replace(/[^0-9.-]+/g, ''), 10) || 0;
                    if (rr && (rr.textContent || rr.innerText)) rateV = parseFloat((rr.textContent || rr.innerText).toString().replace(/[^0-9.-]+/g, '')) || 0;
                    if (rateV && nightsV) derivedExtendedPrice = Math.round(rateV * nightsV * 100) / 100;
                }
            } catch (e) { derivedExtendedPrice = 0; }

            var derivedPaid = 0;
            try {
                // For extend flows prefer the explicit extend payment input so Enter in other
                // modals doesn't leak into the extend success payload.
                var paidIds = ['extendPayAmountInput-' + bid, 'extendPayHiddenAmount-' + bid, 'extendPayHiddenPaidForExtension-' + bid];
                for (var i = 0; i < paidIds.length; i++) {
                    var pEl = document.getElementById(paidIds[i]);
                    if (pEl && (pEl.value || pEl.textContent || pEl.innerText)) {
                        derivedPaid = parseFloat((pEl.value || pEl.textContent || pEl.innerText).toString().replace(/[^0-9.-]+/g, '')) || 0;
                        if (derivedPaid) break;
                    }
                }
            } catch (e) { derivedPaid = 0; }

            // Prefer the displayed Amount Change in the extend-payment modal when present.
            var computedAddedRemain = 0;
            try {
                var changeElDom = document.getElementById('extendChangeDisplayExt-' + bid) || document.getElementById('extendChangeDisplay-' + bid);
                if (changeElDom && (changeElDom.textContent || changeElDom.innerText)) {
                    var parsedChange = parseFloat((changeElDom.textContent || changeElDom.innerText).toString().replace(/[^0-9.-]+/g, '')) || 0;
                    computedAddedRemain = Math.max(0, Math.round(parsedChange * 100) / 100);
                } else {
                    computedAddedRemain = Math.max(0, Math.round((derivedPaid - (derivedExtendedPrice || 0)) * 100) / 100);
                }
            } catch (e) {
                computedAddedRemain = Math.max(0, Math.round((derivedPaid - (derivedExtendedPrice || 0)) * 100) / 100);
            }

            var payload = {
                bookingId: bid,
                newDepartureDate: getText('extendPayHiddenNewDeparture-' + bid) || getText('extendDisplayNewDeparture-' + bid),
                extendedNights: parseInt(getText('extendPayHiddenNights-' + bid) || getText('extendDisplayNights-' + bid) || '0') || 0,
                extendedPrice: derivedExtendedPrice || parseFloat((getText('extendPrice-' + bid) || '').toString().replace(/[^0-9.-]+/g, '')) || 0,
                totalPaid: derivedPaid || parseFloat((getText('extendPayHiddenAmount-' + bid) || getText('extendPayHiddenAmount-' + bid) || getText('extendPayAmountInput-' + bid) || '0')) || 0,
                addedRemain: computedAddedRemain || parseFloat((getText('extendPayHiddenAddedRemain-' + bid) || '0')) || 0,
                newBalance: (function () {
                    try {
                        var raw = getText('extendBalanceRaw-' + bid) || getText('extendPayApplied-' + bid) || getText('extendPayAppliedExt-' + bid) || '0';
                        return parseFloat(raw.toString().replace(/[^0-9.-]+/g, '')) || 0;
                    } catch (e) { return 0; }
                })()
            };

            try {
                sessionStorage.setItem('extendSuccessPayload', JSON.stringify(payload));
                console.debug('extendSuccessPayload saved (submit):', payload);
            } catch (e) { console.error('store payload on submit failed', e); }
            // allow the submit to continue
        } catch (err) { console.error('prepare extend success payload on submit failed', err); }
    });
    </script>
}

<div class="text-ctr"><b> Manage Reservation List </b></div>

<div class="containerbox">
    @if (reservationsList.Any())
    {
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Action</th>
                    <th>ID</th>
                    <th>Status</th>
                    <th>Room Number</th>
                    <th>Last Name</th>
                    <th>Check-In Date</th>
                    <th>Check-Out Date</th>
                    <th>Balance</th>
                    <th>Access By</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in reservationsList)
                {
                    // mark bookings with status Registered so we can render disabled actions
                    var isRegistered = string.Equals(booking.Status, "Registered", StringComparison.OrdinalIgnoreCase);
                    var isReserved = string.Equals(booking.Status, "Reserved", StringComparison.OrdinalIgnoreCase);
                <tr data-booking-id="@booking.Id">
                        <td>
                            <button type="button" class="btn btn-outline-primary btn-sm open-checkin-btn" data-booking-id="@booking.Id" data-bs-toggle="modal" data-bs-target="#checkinModal-@booking.Id">Check-In</button>
                            @if (!isRegistered)
                            {
                                <button type="button" class="btn btn-outline-success btn-sm checkout-open-btn" data-bs-toggle="modal" data-bs-target="#checkoutPriceModal-@booking.Id" data-arrival="@FormatIsoDate(booking.ArrivalDate)" data-arrival-ms="@(booking.ArrivalDate.Year <= 1 ? 0 : new DateTimeOffset(booking.ArrivalDate.ToUniversalTime()).ToUnixTimeMilliseconds())">Check Out</button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-outline-success btn-sm checkout-open-btn disabled" disabled="disabled" aria-disabled="true" data-registered="1">Check Out</button>
                            }

                            @if (!isRegistered)
                            {
                                <button type="button" class="btn btn-outline-primary btn-sm open-extend-btn" data-booking-id="@booking.Id" data-bs-toggle="modal" data-bs-target="#extendModal-@booking.Id">Extend</button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-outline-primary btn-sm open-extend-btn disabled" data-booking-id="@booking.Id" disabled="disabled" aria-disabled="true">Extend</button>
                            }
                            <button type="button" class="btn btn-outline-danger btn-sm open-extend-btn">Cancel</button>
                            @* Show a compact "mini" info modal for bookings marked as Registered; otherwise show the full info modal *@
                            @if (isRegistered)
                            {
                                <button type="button" class="btn btn-outline-info btn-sm" data-bs-toggle="modal" data-bs-target="#miniInfoModal-@booking.Id">Info</button>
                            }
                            else
                            {
                                // For Reserved (check-in) and all other statuses show full info modal
                                <button type="button" class="btn btn-outline-info btn-sm" data-bs-toggle="modal" data-bs-target="#infoModal-@booking.Id">Info</button>
                            }
                        </td>
                        <td>@booking.Id</td>
                        <td><span id="status-@booking.Id">@booking.Status</span></td>
                        <td>@booking.RoomNumber</td>
                        <td>@booking.LastName</td>
                        <td>@(booking.ArrivalDate.Year <= 1 ? string.Empty : booking.ArrivalDate.ToString("M/d/yy"))</td>
                        <td>@(booking.DepartureDate.Year <= 1 ? string.Empty : booking.DepartureDate.ToString("M/d/yy"))</td>
                        <td>@booking.Balance</td>
                        <td>@booking.AccessBy</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="text-center text-muted">No reservations found.</div>
    }
</div>

<!-- Check Out Price Modal -->
@foreach (var booking in Model)
{
    // Check-In Modal: shows room information and allows operator to confirm check-in
    <div class="modal fade" id="checkinModal-@booking.Id" tabindex="-1" aria-labelledby="checkinModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="checkinModalLabel-@booking.Id">Room Information - Check In (@booking.Id)</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Check-In Date</label>
                            @* Use stored arrival date when present, otherwise default to today. Disable past dates but allow future selections. *@
                            @{
                                // Block the next 2 days for check-in; earliest selectable check-in is today + 2
                                var earliestCheckin = DateTime.Today.AddDays(2);
                                var initialCheckin = (booking.ArrivalDate.Date >= earliestCheckin) ? booking.ArrivalDate : earliestCheckin;
                            }
                            <input type="date" class="form-control checkin-date" id="checkinDate-@booking.Id" value="@initialCheckin.ToString("yyyy-MM-dd")" min="@earliestCheckin.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Check-out Date</label>
                            @* By default require check-in first; checkout min will be set to (checkin + 1) via JS. Also prevent selecting past dates. *@
                            <input type="date" class="form-control checkout-date" id="checkoutDate-@booking.Id" value="@FormatIsoDate(booking.DepartureDate)" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Room Type</label>
                            <select class="form-select room-type-select" id="roomTypeSelect-@booking.Id">
                                <option value="">-- Select here --</option>
                                <option value="Standard">Standard</option>
                                <option value="Deluxe">Deluxe</option>
                                <option value="Premium">Premium</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Room Number</label>
                            <select class="form-select room-number-select" id="roomNumberSelect-@booking.Id" @(String.IsNullOrEmpty(booking.RoomNumber) ? "disabled" : "")>
                                <option value="">-- Select Room Type First --</option>
                                @if (!string.IsNullOrEmpty(booking.RoomNumber)) { <option value="@booking.RoomNumber" selected>@booking.RoomNumber</option> }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Room Rates (Price)</label>
                            @{ decimal rr = 0m; decimal.TryParse(Convert.ToString(booking.RoomRates), out rr); }
                            <input type="text" class="form-control room-rates" id="roomRates-@booking.Id" value="@rr.ToString("C0", new System.Globalization.CultureInfo("en-PH"))" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Number of Pax (Capacity)</label>
                            <input type="text" class="form-control pax-capacity" id="pax-@booking.Id" value="@booking.NumberOfPax" readonly />
                        </div>

                        <div class="col-12">
                            <label class="form-label">Guest Names</label>
                            <input type="text" class="form-control" id="guestNames-@booking.Id" value="@booking.GuestNames" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <form asp-action="CheckIn" asp-controller="System" method="post" class="m-0 p-0" id="checkinForm-@booking.Id">
                        <input type="hidden" name="bookingId" value="@booking.Id" />
                        <input type="hidden" name="selectedRoomNumber" id="formRoomNumber-@booking.Id" />
                        <input type="hidden" name="selectedCheckoutDate" id="formCheckoutDate-@booking.Id" />
                        <button type="submit" class="btn btn-primary">Proceed to Check-In</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Confirm Room Details Modal (shown when Proceed to Check-In clicked) -->
    <div class="modal fade" id="confirmCheckinModal-@booking.Id" tabindex="-1" aria-labelledby="confirmCheckinModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmCheckinModalLabel-@booking.Id">Confirm Room Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <table class="table table-sm">
                        <tbody>
                            <tr><th>Check-in Date</th><td id="confirmCheckinDate-@booking.Id"></td></tr>
                            <tr><th>Check-out Date</th><td id="confirmCheckoutDate-@booking.Id"></td></tr>
                            <tr><th>Room Number</th><td id="confirmRoomNumber-@booking.Id"></td></tr>
                            <tr><th>Room Type</th><td id="confirmRoomType-@booking.Id"></td></tr>
                            <tr><th>Room Rates</th><td id="confirmRoomRates-@booking.Id"></td></tr> 
                            <tr><th>Number of Pax</th><td id="confirmPax-@booking.Id"></td></tr>
                            <tr><th>Total Amount</th><td id="confirmTotal-@booking.Id"></td></tr>
                            <tr><th>Guest Names</th><td id="confirmGuestNames-@booking.Id"></td></tr>
                        </tbody>
                    </table>
                    <div>Do you want to confirm this reservation?</div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary confirm-checkin-btn" data-booking-id="@booking.Id">Reserve Now</button>
                </div>
            </div>
        </div>
    </div>
    // Safely parse RoomRates which may be null/empty or non-numeric in some records.
    decimal roomRatesDecimal = 0m;
    // Try current culture first, then invariant as a fallback
    decimal.TryParse(Convert.ToString(booking.RoomRates), System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.CurrentCulture, out roomRatesDecimal);
    if (roomRatesDecimal == 0m)
    {
        decimal.TryParse(Convert.ToString(booking.RoomRates), System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out roomRatesDecimal);
    }
    var stayingDays = (booking.DepartureDate - booking.ArrivalDate).Days; 
    var total = stayingDays * roomRatesDecimal;
    <span id="arrivalDate-@booking.Id" style="display:none">@FormatIsoDate(booking.ArrivalDate)</span>
    <span id="extendBalanceRaw-@booking.Id" style="display:none">@booking.Balance</span>
    <div class="modal fade" id="checkoutPriceModal-@booking.Id" tabindex="-1" aria-labelledby="checkoutPriceModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="checkoutPriceModalLabel-@booking.Id">Check Out Reservation</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <dl class="row">
                        <dt class="col-sm-3">Booking ID</dt>
                        <dd class="col-sm-9">@booking.Id</dd>
                        <dt class="col-sm-3">First Name</dt>
                        <dd class="col-sm-9">@booking.FirstName</dd>
                        <dt class="col-sm-3">Last Name</dt>
                        <dd class="col-sm-9">@booking.LastName</dd>
                        <dt class="col-sm-3">Book/Reserve</dt>
                        <dd class="col-sm-9">@booking.BookReserve</dd>
                        <dt class="col-sm-3">Check-In Date</dt>
                        <dd class="col-sm-9">@(booking.ArrivalDate.Year <= 1 ? string.Empty : booking.ArrivalDate.ToString("yyyy-MM-dd"))</dd>
                        <dt class="col-sm-3">Check-Out Date</dt>
                        <dd class="col-sm-9">@(booking.DepartureDate.Year <= 1 ? string.Empty : booking.DepartureDate.ToString("yyyy-MM-dd"))</dd>
                        <dt class="col-sm-3">Room Number</dt>
                        <dd class="col-sm-9">@booking.RoomNumber</dd>
                        <dt class="col-sm-3">Room Type</dt>
                        <dd class="col-sm-9">@booking.RoomType</dd>
                        <dt class="col-sm-3">Paid Booking</dt>
                        <dd class="col-sm-9"><b>@booking.PaidReserve.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</b></dd>
                    </dl class="row">
                    ----------------------------------------------------------
                    <dl class="row">
                        <dt class="col-sm-5">Number of Pax</dt>
                        <dd class="col-sm-7">@booking.NumberOfPax.ToString()</dd>
                        <dt class="col-sm-5">Room Rates</dt>
                        <dd class="col-sm-7">@roomRatesDecimal.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</dd>
                        <dt class="col-sm-5">Staying Days</dt>
                        <dd class="col-sm-7">@stayingDays.ToString() nights</dd>
                        <dt class="col-sm-5">Extend Balance</dt>
                        <dd class="col-sm-7"><b>@booking.Balance.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</b></dd>
                    </dl>

                    Do you want to check out this selected booking/reservaton?<br/>
                    This action cannot be undone.
                </div>
                    <div class="modal-footer">
                    <!-- remove automatic BS toggles and use class + data attribute for JS control -->
                    <button type="button" class="btn btn-success open-payment-btn" data-booking-id="@booking.Id" data-book-reserve="@booking.BookReserve">Check Out Now</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Payment Modal: match Extend Payment modal layout and behavior but post to CheckOut -->
    <div class="modal fade" id="paymentModal-@booking.Id" tabindex="-1" aria-labelledby="paymentModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="paymentModalLabel-@booking.Id">Payment - Reservation @booking.Id</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @{ 
                        // For payment modal reuse the same layout/behavior as Extend Payment modal but post to CheckOut
                        decimal initialTotalForDisplay = Convert.ToDecimal(total);
                        try {
                            var rawBalObj = booking.Balance;
                            double parsedBal = 0;
                            if (rawBalObj != null) double.TryParse(Convert.ToString(rawBalObj), out parsedBal);
                            if (parsedBal > 0) {
                                initialTotalForDisplay = Convert.ToDecimal(parsedBal);
                            }
                        } catch { }
                    }

                    <div class="mb-2">Total Amount: <strong id="displayTotal-@booking.Id">@initialTotalForDisplay.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</strong></div>
                    @* roomRatesInt removed (unused) *@
                    
                    <div class="mb-3" id="payAmountContainer-@booking.Id">
                        <label for="payAmountInput-@booking.Id" class="form-label">Enter Pay Amount</label>
                        <input type="number" step="0.01" min="0" class="form-control" id="payAmountInput-@booking.Id" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Balance</label>
                        <div id="extendPayApplied-@booking.Id" class="fw-bold">@(0.ToString("C2", new System.Globalization.CultureInfo("en-PH")))</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Amount Change</label>
                        <div id="extendChangeDisplay-@booking.Id" class="fw-bold">@(0.ToString("C2", new System.Globalization.CultureInfo("en-PH")))</div>
                    </div>
                </div>
                <div class="modal-footer">
                    @if (string.Equals(booking.BookReserve, "Reservation", System.StringComparison.OrdinalIgnoreCase) || string.Equals(booking.BookReserve, "Reserve", System.StringComparison.OrdinalIgnoreCase))
                    {
                        <!-- Reservation flow: submit updated reservation values -->
                        <form asp-action="ReserveRoom" asp-controller="System" method="post" id="paymentForm-@booking.Id">
                            <input type="hidden" name="Id" value="@booking.Id" />
                            <input type="hidden" name="ArrivalDate" id="hiddenArrival-@booking.Id" />
                            <input type="hidden" name="DepartureDate" id="hiddenDeparture-@booking.Id" />
                            <input type="hidden" name="RoomType" id="hiddenRoomType-@booking.Id" />
                            <input type="hidden" name="RoomNumber" id="hiddenRoomNumber-@booking.Id" />
                            <input type="hidden" name="RoomRates" id="hiddenRoomRates-@booking.Id" />
                            <input type="hidden" name="NumberOfPax" id="hiddenPax-@booking.Id" />
                            <input type="hidden" name="GuestNames" id="hiddenGuestNames-@booking.Id" />
                            <input type="hidden" name="Total" id="hiddenTotal-@booking.Id" />
                            <input type="hidden" name="Balance" id="hiddenBalance-@booking.Id" />
                            <input type="hidden" name="ChangeReserve" id="hiddenChange-@booking.Id" />
                            <input type="hidden" name="PaidReserve" id="hiddenPaid-@booking.Id" />
                            <button type="submit" class="btn btn-success" id="extendPayNowBtn-@booking.Id">Pay</button>
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        </form>
                    }
                    else
                    {
                        <!-- Booking flow keeps original checkout behavior -->
                        <form asp-action="CheckOut" asp-controller="System" method="post" id="paymentForm-@booking.Id">
                            <input type="hidden" name="bookingId" value="@booking.Id" />
                            <input type="hidden" name="stayingDays" value="@stayingDays" />
                            <input type="hidden" name="grandTotal" value="@initialTotalForDisplay" id="grandTotalHidden-@booking.Id" />
                            <input type="hidden" name="payAmount" id="extendPayHiddenAmount-@booking.Id" />
                        <input type="hidden" name="addedRemain" id="extendPayHiddenAddedRemain-@booking.Id" />
                        @* Hidden field set by client JS: the remaining amount displayed in the extend payment modal.
                           This is the value that should be added to the DB balance (existing + remaining).
                           JS will populate `extendPayHiddenBalanceToAdd-<id>` before submitting the form. *@
                        <input type="hidden" name="balanceToAdd" id="extendPayHiddenBalanceToAdd-@booking.Id" />
                            <input type="hidden" name="existingExtendBalance" id="extendExistingBalance-@booking.Id" value="@booking.Balance" />
                            <input type="hidden" name="paidForExtension" id="extendPayHiddenPaidForExtension-@booking.Id" />
                            <button type="submit" class="btn btn-success" id="extendPayNowBtn-@booking.Id">Pay</button>
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Extend Modal -->
    <div class="modal fade" id="extendModal-@booking.Id" tabindex="-1" aria-labelledby="extendModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="extendModalLabel-@booking.Id">Extend Stay - Reservation @booking.Id</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-2">Original Check-Out Date: <strong id="originalDeparture-@booking.Id">@FormatIsoDate(booking.DepartureDate)</strong></div>

                    @{
                        // Minimum selectable date: at least one day after original departure
                        // and not in the past (use the later of the two). If stored departure is uninitialized use today.
                        var minAfterOriginal = booking.DepartureDate.Year <= 1 ? DateTime.Today : booking.DepartureDate.AddDays(1);
                        var minAfterToday = DateTime.Today.AddDays(1);
                        var minDate = minAfterOriginal > minAfterToday ? minAfterOriginal : minAfterToday;
                    }

                    <div class="mb-3">
                        <label for="newDeparture-@booking.Id" class="form-label">Choose new Check-Out Date</label>
                        <input type="date" id="newDeparture-@booking.Id" class="form-control new-departure" data-booking-id="@booking.Id" min="@minDate.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="text-danger small" id="extendDateError-@booking.Id" style="display:none;"></div>

                    <div class="mb-2">Extended Nights: <strong id="extendedNights-@booking.Id">0</strong></div>
                </div>
                <div class="modal-footer">
                    <input type="hidden" id="extendHiddenNewDeparture-@booking.Id" />
                    <input type="hidden" id="extendHiddenNights-@booking.Id" />
                    <!-- Instead of submitting immediately, open payment modal to pay for extension -->
                    <button type="button" class="btn btn-primary open-extend-payment-btn" data-booking-id="@booking.Id" id="extendNowBtn-@booking.Id" disabled>Extend Now</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Extend Payment Modal -->
    <div class="modal fade" id="extendPaymentModal-@booking.Id" tabindex="-1" aria-labelledby="extendPaymentModalLabel-@booking.Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="extendPaymentModalLabel-@booking.Id">Extend Payment - Reservation @booking.Id</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                        <div class="mb-2">New Check-Out Date: <strong id="extendDisplayNewDeparture-@booking.Id">@FormatIsoDate(booking.DepartureDate)</strong></div>
                    @{ var roomRatesIntExtend = 0; int.TryParse(booking.RoomRates, out roomRatesIntExtend); }
                    @{ 
                        // Parse room rates robustly (support non-numeric, current/invariant cultures)
                        decimal extendRoomRateDecimal = 0m;
                        decimal.TryParse(Convert.ToString(booking.RoomRates), System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.CurrentCulture, out extendRoomRateDecimal);
                        if (extendRoomRateDecimal == 0m)
                        {
                            decimal.TryParse(Convert.ToString(booking.RoomRates), System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out extendRoomRateDecimal);
                        }
                    }
                    <div class="mb-3">Room Rate: <strong id="extendRoomRate-@booking.Id">@extendRoomRateDecimal.ToString("C0", new System.Globalization.CultureInfo("en-PH"))</strong></div>
                    <div class="mb-2">Extended Nights: <strong id="extendDisplayNights-@booking.Id">0</strong></div>
                    <div class="mb-3">Extended Price: <strong id="extendPrice-@booking.Id">@(0.ToString("C2", new System.Globalization.CultureInfo("en-PH")))</strong></div>

                    <div class="mb-3" id="payAmountContainer-@booking.Id">
                        <label for="extendPayAmountInput-@booking.Id" class="form-label">Enter Pay Amount</label>
                        <!-- use a distinct id for the extend-payment input to avoid colliding with the reservation/payment modal -->
                        <input type="number" step="0.01" min="0" class="form-control" id="extendPayAmountInput-@booking.Id" />
                    </div>


                    <div class="mb-3">
                        <label class="form-label">Balance</label>
                        <!-- Balance/Change elements for extend-payment use unique ids to avoid duplicates with other modals -->
                        <div id="extendPayAppliedExt-@booking.Id" class="fw-bold">@(0.ToString("C2", new System.Globalization.CultureInfo("en-PH")))</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Amount Change</label>
                        <div id="extendChangeDisplayExt-@booking.Id" class="fw-bold">@(0.ToString("C2", new System.Globalization.CultureInfo("en-PH")))</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <form asp-action="ExtendAndPayreserve" asp-controller="System" method="post" id="extendPayForm-@booking.Id">
                        <input type="hidden" name="bookingId" value="@booking.Id" />
                        <input type="hidden" name="newDepartureDate" id="extendPayHiddenNewDeparture-@booking.Id" />
                        <input type="hidden" name="extendedNights" id="extendPayHiddenNights-@booking.Id" />
                        <input type="hidden" name="payAmount" id="extendPayHiddenAmount-@booking.Id" />
                        <!-- Hidden field populated by client JS: remaining unpaid portion to add to DB balance -->
                        <input type="hidden" name="balanceToAdd" id="extendPayHiddenBalanceToAdd-@booking.Id" />
                        <input type="hidden" name="addedRemain" id="extendPayHiddenAddedRemain-@booking.Id" />
                        <!-- include current stored ExtendBalance so server can process existing balance -->
                        <input type="hidden" name="existingExtendBalance" id="extendExistingBalance-@booking.Id" value="@booking.Balance" />
                        <input type="hidden" name="paidForExtension" id="extendPayHiddenPaidForExtension-@booking.Id" />
                        <button type="submit" class="btn btn-success" id="extendPayNowBtn-@booking.Id">Pay</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <!-- Direct checkout form for bookings (hidden). This uses booking's stored cash values so payment modal is skipped for Bookings -->
    <form asp-action="CheckOut" asp-controller="System" asp-route-bookingId="@booking.Id" method="post" id="directCheckoutForm-@booking.Id" style="display:none;">
        <input type="hidden" name="stayingDays" value="@stayingDays" />
        <input type="hidden" name="grandTotal" value="@total" />
    </form>
}

