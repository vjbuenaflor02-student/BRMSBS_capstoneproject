@model IEnumerable<BRMSBS_capstoneproject.Models.UserModel>

@{
    ViewData["Title"] = "Staff Account Management";
    Layout = "~/Views/Layouts/ManageStaffLayout.cshtml";
}

<div class="text-ctr"><b> Staff Account Management </b></div>

<div class="containerbox">
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createAccountModal">Create Account</button><br />

    <h5>Created Staff Accounts: @Model.Count() </h5>
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Actions</th>
                <th>Username</th>
                <th>Password</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex gap-2 flex-wrap">
                                <button type="button"
                                        class="btn btn-sm btn-outline-info password-toggle"
                                        data-userid="@user.Id"
                                        title="Toggle password visibility">
                                    <span class="password-toggle-text">Show Password</span>
                                </button>
                                <button type="button"
                                        class="btn btn-sm btn-outline-warning"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editAccountModal"
                                        data-userid="@user.Id"
                                        data-username="@user.Username">
                                    Edit
                                </button>
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteAccountModal"
                                        data-userid="@user.Id"
                                        data-username="@user.Username">
                                    Delete
                                </button>
                            </div>
                        </td>
                        <td>@user.Username</td>
                        <td>
                            <span class="password-display" data-userid="@user.Id" data-password="@user.Password" style="display: none;"></span>
                            <span class="password-hidden" data-userid="@user.Id">●●●●●●●●</span>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3" class="text-center">No staff accounts created.</td>
                </tr>
            }
        </tbody>
    </table>
</div>






<!-- Create Account Modal -->
<div class="modal fade" id="createAccountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" action="/System/CreateAccount" id="createAccountForm">
                <div class="modal-header">
                    <h5 class="modal-title" id="createAccountModalLabel">Create Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="username" class="form-label">Username</label>
                        <input type="text" class="form-control" id="username" name="Username" required />
                    </div>
                    <input type="hidden" id="generatedPassword" name="Password" />

                    Password can be generated after creating the staff account. 
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Create</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Account Modal -->
<div class="modal fade" id="editAccountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" action="/System/EditAccount">
                <div class="modal-header">
                    <h5 class="modal-title" id="editAccountModalLabel">Edit Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editUserId" name="Id" />
                    <div class="mb-3">
                        <label for="editUsername" class="form-label">Username</label>
                        <input type="text" class="form-control" id="editUsername" name="Username" required />
                    </div>
                    <div class="mb-3">
                        <label for="editPassword" class="form-label">New Password</label>
                        <input type="password" class="form-control" id="editPassword" name="Password"
                               pattern="^(?=.*\d)(?=.*[^\w\s]).{8,}$"
                               title="Password must be at least 8 characters, include a number and a symbol." />
                        <small class="form-text text-muted">Leave blank to keep current password.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-warning">Save Changes</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Account Confirmation Modal -->
<div class="modal fade" id="deleteAccountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" action="/System/DeleteAccount">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="deleteAccountModalLabel">Delete Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="deleteUserId" name="Id" />
                    <p>Are you sure you want to delete the account <b id="deleteUsername"></b>?</p>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Success Popup Modal for Create -->
<div class="modal fade" id="successAccountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="successModalLabel">Success!</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p>Staff Account has been created</p>
                <p class="mt-3"><strong>Generated Password:</strong></p>
                <p id="displayGeneratedPassword" class="text-monospace" style="background-color: #f0f0f0; padding: 10px; border-radius: 4px; font-family: monospace;"></p>
            </div>
        </div>
    </div>
</div>

<!-- Success Popup Modal for Edit -->
<div class="modal fade" id="successEditModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="successModalLabel">Success!</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p>Staff Account has been updated</p>
                <div id="passwordChangedSection" style="display: none;">
                    <p class="mt-3"><strong>Password Changed:</strong></p>
                    <p id="displayChangedPassword" class="text-monospace" style="background-color: #f0f0f0; padding: 10px; border-radius: 4px; font-family: monospace;"></p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Success Popup Modal for Delete -->
<div class="modal fade" id="successDeleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="successModalLabel">Success!</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                Staff Account has been deleted
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Generate random password meeting security requirements - simpler format
        function generateRandomPassword() {
            const lowercase = 'abcdefghijklmnopqrstuvwxyz';
            const uppercase = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
            const numbers = '0123456789';
            const symbols = '@@#$-!';

            let password = '';

            // Add 1 uppercase letter at start
            password += uppercase[Math.floor(Math.random() * uppercase.length)];

            // Add 5 random lowercase letters
            for (let i = 0; i < 5; i++) {
                password += lowercase[Math.floor(Math.random() * lowercase.length)];
            }

            // Add 4 random numbers
            for (let i = 0; i < 4; i++) {
                password += numbers[Math.floor(Math.random() * numbers.length)];
            }

            // Add 1 symbol at the end
            password += symbols[Math.floor(Math.random() * symbols.length)];

            return password;
        }

        // Show success modal if account was created
        window.addEventListener('DOMContentLoaded', function () {
            @if (TempData["AccountCreated"] != null)
            {
                <text>
                var successModal = new bootstrap.Modal(document.getElementById('successAccountModal'));

                // Retrieve password from sessionStorage if available
                var storedPassword = sessionStorage.getItem('generatedPassword');
                if (storedPassword) {
                    document.getElementById('displayGeneratedPassword').textContent = storedPassword;
                    sessionStorage.removeItem('generatedPassword');
                }

                successModal.show();
                </text>
            }
            @if (TempData["AccountEdited"] != null)
            {
                <text>
                var successEditModal = new bootstrap.Modal(document.getElementById('successEditModal'));

                // Retrieve password from sessionStorage if available
                var storedPassword = sessionStorage.getItem('changedPassword');
                if (storedPassword) {
                    document.getElementById('passwordChangedSection').style.display = 'block';
                    document.getElementById('displayChangedPassword').textContent = storedPassword;
                    sessionStorage.removeItem('changedPassword');
                }

                successEditModal.show();
                </text>
            }
            @if (TempData["AccountDeleted"] != null)
            {
                <text>
                var successDeleteModal = new bootstrap.Modal(document.getElementById('successDeleteModal'));
                successDeleteModal.show();
                </text>
            }

            // Handle Create Account form submission
            var createAccountForm = document.getElementById('createAccountForm');
            if (createAccountForm) {
                createAccountForm.addEventListener('submit', function (event) {
                    event.preventDefault();

                    // Generate password
                    var generatedPassword = generateRandomPassword();
                    document.getElementById('generatedPassword').value = generatedPassword;

                    // Store password in sessionStorage to survive page reload
                    sessionStorage.setItem('generatedPassword', generatedPassword);

                    // Submit the form
                    this.submit();
                });
            }
        });

        // Populate Edit Account Modal with user data
        var editAccountModal = document.getElementById('editAccountModal');
        editAccountModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var userId = button.getAttribute('data-userid');
            var username = button.getAttribute('data-username');

            var modalUserId = editAccountModal.querySelector('#editUserId');
            var modalUsername = editAccountModal.querySelector('#editUsername');
            var modalPassword = editAccountModal.querySelector('#editPassword');

            modalUserId.value = userId;
            modalUsername.value = username;
            modalPassword.value = '';
        });

        // Handle Edit Account form submission
        var editAccountForm = editAccountModal.querySelector('form');
        if (editAccountForm) {
            editAccountForm.addEventListener('submit', function (event) {
                var newPassword = editAccountModal.querySelector('#editPassword').value;

                // Store password in sessionStorage if a new password was entered
                if (newPassword && newPassword.trim() !== '') {
                    sessionStorage.setItem('changedPassword', newPassword);
                } else {
                    sessionStorage.removeItem('changedPassword');
                }
            });
        }

        // Populate Delete Account Modal with user data
        var deleteAccountModal = document.getElementById('deleteAccountModal');
        deleteAccountModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var userId = button.getAttribute('data-userid');
            var username = button.getAttribute('data-username');

            var modalUserId = deleteAccountModal.querySelector('#deleteUserId');
            var modalUsername = deleteAccountModal.querySelector('#deleteUsername');

            modalUserId.value = userId;
            modalUsername.textContent = username;
        });

        // Handle password toggle visibility
        document.addEventListener('click', function (event) {
            if (event.target.closest('.password-toggle')) {
                event.preventDefault();
                var toggleButton = event.target.closest('.password-toggle');
                var userId = toggleButton.getAttribute('data-userid');

                var passwordDisplay = document.querySelector(`.password-display[data-userid="${userId}"]`);
                var passwordHidden = document.querySelector(`.password-hidden[data-userid="${userId}"]`);
                var toggleText = toggleButton.querySelector('.password-toggle-text');

                if (passwordDisplay.style.display === 'none') {
                    passwordDisplay.textContent = passwordDisplay.getAttribute('data-password');
                    passwordDisplay.style.display = 'inline';
                    passwordHidden.style.display = 'none';
                    toggleButton.classList.remove('btn-outline-info');
                    toggleButton.classList.add('btn-info');
                    if (toggleText) toggleText.textContent = 'Hide Password';
                } else {
                    passwordDisplay.style.display = 'none';
                    passwordHidden.style.display = 'inline';
                    toggleButton.classList.add('btn-outline-info');
                    toggleButton.classList.remove('btn-info');
                    if (toggleText) toggleText.textContent = 'Show Password';
                }
            }
        });
    </script>
}
