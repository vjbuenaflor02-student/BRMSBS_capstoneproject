@{
    ViewData["Title"] = "Reservation";
    Layout = "~/Views/Layouts/ReservationLayoutS.cshtml";
    var rooms = ViewBag.Rooms as List<BRMSBS_capstoneproject.Models.RoomModel>;
}

<div class="text-ctr"><b> Make a reservation </b></div>

<div class="containerbox">

     <form class="formbox" method="post" id="bookingForm" asp-controller="System" asp-action="ReserveRoomStaff" autocomplete="off">
        @Html.AntiForgeryToken()
        <b>Client Form</b>

        <div class="form-group row mb-3">
            <label for="FirstName" class="col-4 col-form-label">First Name</label>
            <div class="col-8">
                <input type="text" class="form-control" id="FirstName" name="FirstName" required />
            </div>
        </div>

        <div class="form-group row mb-3">
            <label for="LastName" class="col-4 col-form-label">Last Name</label>
            <div class="col-8">
                <input type="text" class="form-control" id="LastName" name="LastName" required />
            </div>
        </div>

        <div class="form-group row mb-3">
            <label for="MI" class="col-4 col-form-label">M.I.</label>
            <div class="col-3">
                <input type="text" class="form-control" id="MI" name="MI" required />
            </div>
        </div>

        <div class="form-group row mb-3">
            <label for="Address" class="col-4 col-form-label">Address</label>
            <div class="col-8">
                <input type="text" class="form-control" id="Address" name="Address" required />
            </div>
        </div>

        <div class="form-group row mb-3">
            <label for="Email" class="col-4 col-form-label">Email Address</label>
            <div class="col-8">
                <input type="text" class="form-control" id="Email" name="Email" required />
            </div>
        </div>

        <div class="form-group row mb-3">
            <label for="ContactNumber" class="col-4 col-form-label">Contact Number</label>
            <div class="col-8">
                <input type="tel" class="form-control" id="ContactNumber" name="ContactNumber" required />
            </div>
        </div>

        <div class="form-group row mb-3">
            <label for="Nationality" class="col-4 col-form-label">Nationality</label>
            <div class="col-8">
                <select class="form-control" id="Nationality" name="Nationality" required>
                    <option value="">-- Select here --</option>
                    <option value="Filipino">Filipino</option>
                    <option value="Others">Others</option>
                </select>
            </div>
        </div>

        <div class="form-group row mb-3">
            <label for="Purpose" class="col-4 col-form-label">Purpose</label>
            <div class="col-8">
                <input type="text" class="form-control" id="Purpose" name="Purpose" required />
            </div>
        </div>

        <b>Room Form</b>

        <div class="form-group row mb-2">
            <label for="ArrivalDate" class="col-sm-4 col-form-label">Check-In Date</label>
            <div class="col-sm-3">
                <input type="date" class="form-control" id="ArrivalDate" name="ArrivalDate" required
                       value="@DateTime.Now.AddDays(2).ToString("yyyy-MM-dd")"
                       min="@DateTime.Now.AddDays(2).ToString("yyyy-MM-dd")" />
            </div>
        </div>

        <div class="form-group row mb-2">
            <label for="DepartureDate" class="col-sm-4 col-form-label">Check-out Date</label>
            <div class="col-sm-3">
                <input type="date" class="form-control" id="DepartureDate" name="DepartureDate" required
                       value="@DateTime.Now.AddDays(3).ToString("yyyy-MM-dd")"
                       min="@DateTime.Now.AddDays(3).ToString("yyyy-MM-dd")" />
            </div>
        </div>

        <div class="form-group row mb-3">
            <label for="RoomType" class="col-4 col-form-label">Room Type</label>
            <div class="col-3">
                <select class="form-control" id="RoomType" name="RoomType" required>
                    <option value="">-- Select here --</option>
                    <option value="Standard">Standard</option>
                    <option value="Deluxe">Deluxe</option>
                    <option value="Premium">Premium</option>
                </select>
            </div>
        </div>

        <div class="form-group row mb-3">
            <label for="RoomNumber" class="col-4 col-form-label">Room Number</label>
            <div class="col-5">
                <!-- Start with a placeholder and disabled until RoomType is selected and available rooms exist -->
                <select class="form-control" id="RoomNumber" name="RoomNumber" required disabled>
                    <option value="">-- Select Room Type First --</option>
                </select>
            </div>
        </div>

        <div class="form-group row mb-3">
            <label for="RoomRates" class="col-4 col-form-label">Room Rates (Price)</label>
            <div class="col-3">
                <!-- Show selected room price here. Readonly so JS can populate it when a room number is chosen. -->
                <input type="text" class="form-control" id="RoomRates" name="RoomRates" readonly placeholder="Select Room#" />
            </div>
        </div>

        <div class="form-group row mb-3">
            <label for="NumberOfPax" class="col-4 col-form-label">Number of Pax (Capacity)</label>
            <div class="col-3">
                <input type="number" class="form-control" id="NumberOfPax" name="NumberOfPax" readonly placeholder="???" />
            </div>
        </div>

        <div class="form-group row mb-3">
            <label for="GuestNames" class="col-4 col-form-label">Guest Names</label>
            <div class="col-8">
                <input type="text" class="form-control" id="GuestNames" name="GuestNames" />
            </div>
        </div>

        <!-- Hidden fields for reservation data -->
        <input type="hidden" id="Id" name="Id" />
        <input type="hidden" id="PaidReserve" name="PaidReserve" />

        <div class="form-group row mb-3">
            <div class="col-12 d-flex justify-content-end">
                <button type="button" class="btn btn-primary" id="bookNowBtn">Proceed Reservation</button>
            </div>
        </div>

        <div class="form-group row mb-3">
            <div class="col-12 text-end">
                <div id="registerMissing" class="text-danger small" aria-live="polite"></div>
            </div>
        </div>


     </form>

    <style>
        /* Ensure modals are on top when visible */
        #confirmModal.modal.show,
        #confirmRoomModal.modal.show,
        #paymentModal.modal.show,
        #reserveSuccessModal.modal.show {
            z-index: 1060 !important;
        }

        /* Backdrop styling - dark overlay for visibility */
        .modal-backdrop.show {
            opacity: 0.7 !important;
            background-color: rgba(0,0,0,0.8) !important;
            z-index: 1050 !important;
        }

        /* Ensure modal content is opaque and on top */
        #confirmModal .modal-content,
        #confirmRoomModal .modal-content,
        #paymentModal .modal-content,
        #reserveSuccessModal .modal-content {
            background-color: #fff;
            position: relative;
            z-index: 1051;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.5);
        }

        /* Ensure modal body and tables display at full width */
        #confirmModal .modal-body,
        #confirmRoomModal .modal-body {
            padding: 20px;
        }

        #confirmModal .modal-body table,
        #confirmRoomModal .modal-body table {
            width: 100%;
            margin-bottom: 0;
            table-layout: fixed;
        }

        #confirmModal .modal-body table th,
        #confirmRoomModal .modal-body table th {
            word-wrap: break-word;
            overflow-wrap: break-word;
        }

        #confirmModal .modal-body table td,
        #confirmRoomModal .modal-body table td {
            word-wrap: break-word;
            overflow-wrap: break-word;
        }

        /* Custom success header style */
        .success-modal-header {
            background-color: #1e8746; /* green similar to screenshot */
            color: #fff;
            padding: 15px 20px;
            border: none;
            font-weight: 600;
        }

        .success-modal-title {
            margin: 0;
            font-weight: 600;
            font-size: 1.25rem;
        }

        /* Success modal specific styling */
        #reserveSuccessModal .modal-body {
            padding: 20px;
            text-align: center;
            font-size: 1rem;
        }

        /* Payment modal specific width */
        #paymentModal .modal-dialog {
            max-width: 600px !important;
            width: 90% !important;
        }

        #paymentModal .modal-body {
            padding: 20px;
        }
    </style>

    <!-- Confirmation modal - Personal Details -->
    <div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="confirmModalLabel">Confirm Personal Details</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <table class="table table-bordered">
              <tbody>
                <tr><th style="width:40%">First Name</th><td id="cmFirstName"></td></tr>
                <tr><th>Last Name</th><td id="cmLastName"></td></tr>
                <tr><th>M.I.</th><td id="cmMI"></td></tr>
                <tr><th>Address</th><td id="cmAddress"></td></tr>
                <tr><th>Email</th><td id="cmEmail"></td></tr>
                <tr><th>Contact Number</th><td id="cmContactNumber"></td></tr>
                <tr><th>Nationality</th><td id="cmNationality"></td></tr>
                <tr><th>Purpose</th><td id="cmPurpose"></td></tr>
                <tr><th>Guest Names</th><td id="cmGuestNames"></td></tr>
              </tbody>
            </table>
            <p>Please verify the above personal information. Click "Next" to proceed to room details.</p>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-primary" id="nextBtn">Next</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Confirmation modal - Room Details -->
    <div class="modal fade" id="confirmRoomModal" tabindex="-1" aria-labelledby="confirmRoomModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="confirmRoomModalLabel">Confirm Room Details</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <table class="table table-bordered">
              <tbody>
                <tr><th style="width:40%">Check-in Date</th><td id="cmArrivalDate"></td></tr>
                <tr><th>Check-out Date</th><td id="cmDepartureDate"></td></tr>
                <tr><th>Room Number</th><td id="cmRoomNumber"></td></tr>
                <tr><th>Room Type</th><td id="cmRoomType"></td></tr>
                <tr><th>Room Rates</th><td id="cmRoomRates"></td></tr>
                <tr><th>Number of Pax</th><td id="cmNumberOfPax"></td></tr>
                <tr><th>Total Amount</th><td id="cmTotalAmount"></td></tr>
              </tbody>
            </table>
            Do you want to confirm this reservation?
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-primary" id="reserveNowBtn">Reserve Now</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Payment modal -->
    <div class="modal fade" id="paymentModal" tabindex="-1" aria-labelledby="paymentModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="paymentModalLabel">Payment</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label">Total</label>
              <p class="fs-4 fw-bold" id="PaymentTotal">₱0.00</p>
            </div>
            <div class="mb-3">
              <label for="PaymentAmount" class="form-label">Pay (Enter amount)</label>
              <input type="number" class="form-control" id="PaymentAmount" placeholder="0.00" step="0.01" />
            </div>
            <div class="mb-3">
              <label class="form-label">Amount Balance:</label>
              <p class="fs-5 fw-bold" id="AmountBalance">--</p>
            </div>
            <div class="mb-3">
              <label class="form-label">Amount Change:</label>
              <p class="fs-5 fw-bold" id="AmountChange">₱0.00</p>
            </div>
            <p class="text-muted small">Enter cash amount then click "Pay".</p>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" id="cancelPaymentBtn" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-success" id="payBtn" disabled>Pay</button>
          </div>
        </div>
      </div>
    </div>

    <script>
        (function() {
            var form = document.getElementById('bookingForm');
            var btn = document.getElementById('bookNowBtn');
            var msg = document.getElementById('registerMissing');
            var confirmModalEl = document.getElementById('confirmModal');
            var confirmRoomModalEl = document.getElementById('confirmRoomModal');
            var nextBtn = document.getElementById('nextBtn');
            var reserveNowBtn = document.getElementById('reserveNowBtn');
            var paymentModalEl = document.getElementById('paymentModal');
            var successModalEl = document.getElementById('reserveSuccessModal');

            // Move modals to body so they won't inherit ancestor opacity
            function moveModalToBody(modalEl) {
                if (modalEl && modalEl.parentElement && modalEl.parentElement !== document.body) {
                    try {
                        document.body.appendChild(modalEl);
                    } catch (e) {
                        // ignore if move fails
                    }
                }
            }
            moveModalToBody(confirmModalEl);
            moveModalToBody(confirmRoomModalEl);
            moveModalToBody(paymentModalEl);
            if (successModalEl) {
                moveModalToBody(successModalEl);
            }

            if (!form || !btn || !msg) return;

            // Disable proceed button initially
            btn.disabled = true;

            function isEmptyControl(ctrl) {
                if (ctrl.type === 'checkbox' || ctrl.type === 'radio') return !ctrl.checked;
                var v = ctrl.value;
                return v === null || String(v).trim() === '';
            }

            function getFriendlyName(ctrl) {
                if (ctrl.id) {
                    var lab = form.querySelector('label[for="' + ctrl.id + '"]');
                    if (lab) return lab.textContent.trim().replace(/\s+/g, ' ');
                }
                if (ctrl.getAttribute && ctrl.getAttribute('aria-label')) return ctrl.getAttribute('aria-label');
                if (ctrl.name) return ctrl.name;
                return ctrl.id || 'field';
            }

            function getMissingList() {
                var requiredControls = Array.prototype.slice.call(form.querySelectorAll('[required]'));
                var missing = requiredControls.filter(isEmptyControl).map(function(c) {
                    return c.id || getFriendlyName(c);
                });
                return missing;
            }

            function getRoomMissingList() {
                var roomFields = ['ArrivalDate', 'DepartureDate', 'RoomType', 'RoomNumber'];
                var missing = [];
                roomFields.forEach(function(fieldId) {
                    var ctrl = document.getElementById(fieldId);
                    if (ctrl && isEmptyControl(ctrl)) {
                        missing.push(getFriendlyName(ctrl));
                    }
                });
                return missing;
            }

            function updateButtonState() {
                var missing = getMissingList();
                var roomMissing = getRoomMissingList();
                var allMissing = missing.concat(roomMissing);

                if (allMissing.length === 0) {
                    btn.disabled = false;
                    msg.textContent = '';
                } else {
                    btn.disabled = true;
                    msg.textContent = 'Missing: ' + (allMissing[0] || 'field');
                }
            }

            // Attach listeners to inputs/selects inside the form
            var controls = form.querySelectorAll('input, select, textarea');
            controls.forEach(function(ctrl) {
                ctrl.addEventListener('input', updateButtonState);
                ctrl.addEventListener('change', updateButtonState);
            });

            // Initial check in case browser autofills
            updateButtonState();

            // Room management: link RoomType with RoomNumber, RoomRates, and NumberOfPax
            var roomTypeSelect = document.getElementById('RoomType');
            var roomNumberSelect = document.getElementById('RoomNumber');
            var roomRatesInput = document.getElementById('RoomRates');
            var numberOfPaxInput = document.getElementById('NumberOfPax');
            var arrivalDateInput = document.getElementById('ArrivalDate');
            var departureDateInput = document.getElementById('DepartureDate');

            // Store rooms data from the server
            var allRooms = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(rooms ?? new List<BRMSBS_capstoneproject.Models.RoomModel>()));

            console.log('All rooms loaded:', allRooms);
            console.log('Total rooms:', allRooms.length);

            // Update departure date minimum when arrival date changes
            if (arrivalDateInput && departureDateInput) {
                arrivalDateInput.addEventListener('change', function() {
                    if (arrivalDateInput.value) {
                        var arrivalDate = new Date(arrivalDateInput.value);
                        // Set departure date minimum to day after arrival
                        var nextDay = new Date(arrivalDate);
                        nextDay.setDate(nextDay.getDate() + 1);
                        var minDepartureDate = nextDay.toISOString().split('T')[0];
                        departureDateInput.min = minDepartureDate;

                        // Reset departure date if it's before the new minimum
                        if (!departureDateInput.value || departureDateInput.value <= arrivalDateInput.value) {
                            departureDateInput.value = minDepartureDate;
                        }
                    }

                    // Re-populate rooms when dates change
                    populateRoomNumbers();
                    updateButtonState();
                });
            }

            function populateRoomNumbers() {
                var selectedRoomType = roomTypeSelect.value;
                console.log('Selected Room Type:', selectedRoomType);
                console.log('All Rooms:', allRooms);

                roomNumberSelect.innerHTML = '<option value="">-- Select Room Number --</option>';
                roomRatesInput.value = '';
                numberOfPaxInput.value = '';

                if (!selectedRoomType) {
                    roomNumberSelect.disabled = true;
                    roomNumberSelect.innerHTML = '<option value="">-- Select Room Type First --</option>';
                    return;
                }

                // Filter rooms by selected room type and check availability
                var availableRooms = allRooms.filter(function(room) {
                    console.log('Checking room:', room.RoomNumber, 'Type:', room.RoomType, 'Status:', room.Status);

                    if (room.RoomType !== selectedRoomType) {
                        console.log('  -> Room type mismatch');
                        return false;
                    }

                    // Check if room is available (Status property)
                    // Only show Available rooms
                    if (room.Status && room.Status !== 'Available') {
                        console.log('  -> Room not available, status:', room.Status);
                        return false;
                    }

                    console.log('  -> Room is available!');
                    return true;
                });

                console.log('Filtered available rooms:', availableRooms);

                if (availableRooms.length === 0) {
                    roomNumberSelect.disabled = true;
                    roomNumberSelect.innerHTML = '<option value="">No Available</option>';
                    return;
                }

                roomNumberSelect.disabled = false;
                availableRooms.forEach(function(room) {
                    var option = document.createElement('option');
                    option.value = room.RoomNumber;
                    option.textContent = room.RoomNumber;
                    option.dataset.rate = room.RoomPrice;
                    option.dataset.capacity = room.RoomCapacity;
                    roomNumberSelect.appendChild(option);
                });
            }

            function updateRoomDetails() {
                var selectedOption = roomNumberSelect.options[roomNumberSelect.selectedIndex];
                if (selectedOption && selectedOption.value) {
                    roomRatesInput.value = selectedOption.dataset.rate || '';
                    numberOfPaxInput.value = selectedOption.dataset.capacity || '';
                } else {
                    roomRatesInput.value = '';
                    numberOfPaxInput.value = '';
                }
            }

            if (roomTypeSelect) {
                roomTypeSelect.addEventListener('change', function() {
                    populateRoomNumbers();
                    updateRoomDetails();
                    updateButtonState();
                });
            }

            if (roomNumberSelect) {
                roomNumberSelect.addEventListener('change', function() {
                    updateRoomDetails();
                    updateButtonState();
                });
            }

            // Initialize room numbers if room type is already selected
            if (roomTypeSelect && roomTypeSelect.value) {
                populateRoomNumbers();
            }

            function calculateTotalAmount() {
                var arrivalDate = new Date(arrivalDateInput.value);
                var departureDate = new Date(departureDateInput.value);
                var nights = Math.ceil((departureDate - arrivalDate) / (1000 * 60 * 60 * 24));
                var roomRate = parseFloat(roomRatesInput.value) || 0;
                return roomRate * nights;
            }

            function populatePersonalDetailsModal() {
                function set(id, value) {
                    var el = document.getElementById(id);
                    if (!el) return;
                    el.textContent = value || '';
                }

                set('cmFirstName', document.getElementById('FirstName')?.value);
                set('cmLastName', document.getElementById('LastName')?.value);
                set('cmMI', document.getElementById('MI')?.value);
                set('cmAddress', document.getElementById('Address')?.value);
                set('cmEmail', document.getElementById('Email')?.value);
                set('cmContactNumber', document.getElementById('ContactNumber')?.value);
                var nat = document.getElementById('Nationality')?.value;
                set('cmNationality', nat);
                set('cmPurpose', document.getElementById('Purpose')?.value);
                set('cmGuestNames', document.getElementById('GuestNames')?.value);
            }

            function populateRoomDetailsModal() {
                function set(id, value) {
                    var el = document.getElementById(id);
                    if (!el) return;
                    el.textContent = value || '';
                }

                set('cmArrivalDate', document.getElementById('ArrivalDate')?.value);
                set('cmDepartureDate', document.getElementById('DepartureDate')?.value);
                set('cmRoomNumber', document.getElementById('RoomNumber')?.value);
                set('cmRoomType', document.getElementById('RoomType')?.value);
                set('cmRoomRates', document.getElementById('RoomRates')?.value);
                set('cmNumberOfPax', document.getElementById('NumberOfPax')?.value);

                var totalAmount = calculateTotalAmount();
                var nights = Math.ceil((new Date(document.getElementById('DepartureDate').value) - new Date(document.getElementById('ArrivalDate').value)) / (1000 * 60 * 60 * 24));
                set('cmTotalAmount', '₱' + totalAmount.toLocaleString() + ' (' + nights + ' nights)');
            }

            function showPersonalDetailsModal() {
                // Prefer Bootstrap 5 JS API, fallback to jQuery if present
                if (window.bootstrap && bootstrap.Modal) {
                    var m = bootstrap.Modal.getInstance(confirmModalEl) || new bootstrap.Modal(confirmModalEl);
                    m.show();
                } else if (window.jQuery && typeof jQuery.fn.modal === 'function') {
                    jQuery(confirmModalEl).modal('show');
                }
            }

            function showRoomDetailsModal() {
                // Prefer Bootstrap 5 JS API, fallback to jQuery if present
                if (window.bootstrap && bootstrap.Modal) {
                    var m = bootstrap.Modal.getInstance(confirmRoomModalEl) || new bootstrap.Modal(confirmRoomModalEl);
                    m.show();
                } else if (window.jQuery && typeof jQuery.fn.modal === 'function') {
                    jQuery(confirmRoomModalEl).modal('show');
                }
            }

            function hidePersonalDetailsModal() {
                if (window.bootstrap && bootstrap.Modal) {
                    var m = bootstrap.Modal.getInstance(confirmModalEl);
                    if (m) m.hide();
                } else if (window.jQuery && typeof jQuery.fn.modal === 'function') {
                    jQuery(confirmModalEl).modal('hide');
                }
            }

            btn.addEventListener('click', function () {
                if (!form.checkValidity()) {
                    form.reportValidity();
                    msg.textContent = 'Please correct the highlighted fields before proceeding.';
                    var firstInvalid = form.querySelector(':invalid');
                    if (firstInvalid) firstInvalid.focus();
                    return;
                }

                // Populate and show personal details confirmation modal
                populatePersonalDetailsModal();
                showPersonalDetailsModal();
            });

            if (nextBtn) {
                nextBtn.addEventListener('click', function () {
                    // Hide personal details modal
                    hidePersonalDetailsModal();

                    // Populate and show room details modal
                    populateRoomDetailsModal();
                    showRoomDetailsModal();
                });
            }

            // Payment modal handlers
            var paymentAmountInput = document.getElementById('PaymentAmount');
            var amountBalanceDisplay = document.getElementById('AmountBalance');
            var amountChangeDisplay = document.getElementById('AmountChange');
            var payBtn = document.getElementById('payBtn');
            var cancelPaymentBtn = document.getElementById('cancelPaymentBtn');

            // Store form data for final submission with payment
            var pendingFormData = null;

            if (reserveNowBtn) {
                reserveNowBtn.addEventListener('click', function () {
                    // Hide room details modal
                    if (window.bootstrap && bootstrap.Modal) {
                        var m = bootstrap.Modal.getInstance(confirmRoomModalEl);
                        if (m) m.hide();
                    } else if (window.jQuery && typeof jQuery.fn.modal === 'function') {
                        jQuery(confirmRoomModalEl).modal('hide');
                    }

                    // Store the form data without payment for later submission
                    pendingFormData = new FormData(form);

                    // Validate reservation data with the backend
                    fetch(form.getAttribute('action'), {
                        method: 'POST',
                        body: pendingFormData,
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then(function(response) {
                        if (!response.ok) {
                            throw new Error('Failed to validate reservation');
                        }
                        return response.json();
                    })
                    .then(function(data) {
                        if (data.success) {
                            // Store form data for final submission and show payment modal
                            showPaymentModal();
                        } else {
                            msg.textContent = 'Error: ' + (data.message || 'Failed to validate reservation');
                        }
                    })
                    .catch(function(error) {
                        console.error('Error:', error);
                        msg.textContent = 'Error validating reservation. Please try again.';
                    });
                });
            }

            // Payment modal handlers (moved before payBtn usage)

            function showPaymentModal() {
                // Calculate and display total amount
                var totalAmount = calculateTotalAmount();
                var totalDisplay = document.getElementById('PaymentTotal');
                if (totalDisplay) {
                    totalDisplay.textContent = '₱' + totalAmount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                }

                // Reset payment form
                paymentAmountInput.value = '';

                // Initialize balance to zero (default)
                amountBalanceDisplay.textContent = '₱0.00';
                amountChangeDisplay.textContent = '₱0.00';
                payBtn.disabled = true;

                if (window.bootstrap && bootstrap.Modal) {
                    var m = bootstrap.Modal.getInstance(paymentModalEl) || new bootstrap.Modal(paymentModalEl);
                    m.show();
                } else if (window.jQuery && typeof jQuery.fn.modal === 'function') {
                    jQuery(paymentModalEl).modal('show');
                }
            }

            function hidePaymentModal() {
                if (window.bootstrap && bootstrap.Modal) {
                    var m = bootstrap.Modal.getInstance(paymentModalEl);
                    if (m) m.hide();
                } else if (window.jQuery && typeof jQuery.fn.modal === 'function') {
                    jQuery(paymentModalEl).modal('hide');
                }
            }

            if (paymentAmountInput) {
                paymentAmountInput.addEventListener('input', function () {
                    var totalAmount = calculateTotalAmount();
                    var paymentAmountStr = paymentAmountInput.value.trim();

                    // Only update if user has entered a value
                    if (paymentAmountStr === '') {
                        // No input yet - show zero balance
                        amountBalanceDisplay.textContent = '₱0.00';
                        amountChangeDisplay.textContent = '₱0.00';
                        payBtn.disabled = true;
                        return;
                    }

                    var paymentAmount = parseFloat(paymentAmountStr) || 0;
                    var balance = totalAmount - paymentAmount;
                    var change = paymentAmount - totalAmount;

                    // Update balance display (amount still owed)
                    amountBalanceDisplay.textContent = '₱' + Math.max(0, balance).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

                    // Update change display (excess payment if any)
                    amountChangeDisplay.textContent = '₱' + Math.max(0, change).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

                    // Enable/disable pay button: must be >= 750
                    payBtn.disabled = paymentAmount < 750;
                });
            }

            if (payBtn) {
                payBtn.addEventListener('click', function () {
                    // Validate payment amount
                    var paymentAmount = parseFloat(paymentAmountInput.value) || 0;
                    if (paymentAmount < 750) {
                        msg.textContent = 'Error: Minimum payment is ₱750.00';
                        payBtn.disabled = false;
                        return;
                    }

                    // Prevent double submit
                    payBtn.disabled = true;

                    // Create form data with payment amount
                    var finalFormData = new FormData(form);
                    finalFormData.set('PaidReserve', paymentAmount.toFixed(2));

                    // Hide payment modal
                    hidePaymentModal();

                    // Submit form with payment via AJAX
                    fetch(form.getAttribute('action'), {
                        method: 'POST',
                        body: finalFormData,
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then(function(response) {
                        if (!response.ok) {
                            throw new Error('Failed to submit reservation');
                        }
                        return response.json();
                    })
                    .then(function(data) {
                        if (data.success) {
                            // Reset form for next reservation
                            form.reset();
                            document.getElementById('Id').value = '';
                            pendingFormData = null;

                            // Set flag to show success modal after reload
                            localStorage.setItem('showSuccessModal', 'true');

                            // Refresh page
                            window.location.reload();
                        } else {
                            msg.textContent = 'Error: ' + (data.message || 'Failed to submit reservation');
                            payBtn.disabled = false;
                        }
                    })
                    .catch(function(error) {
                        console.error('Error:', error);
                        msg.textContent = 'Error submitting reservation. Please try again.';
                        payBtn.disabled = false;
                    });
                });
            }

            if (cancelPaymentBtn) {
                cancelPaymentBtn.addEventListener('click', function () {
                    hidePaymentModal();
                });
            }
        })();
    </script>
    <!-- Success modal shown after reservation saved -->
    <div class="modal fade" id="reserveSuccessModal" tabindex="-1" aria-labelledby="reserveSuccessLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header bg-success text-white">
            <h5 class="modal-title" id="reserveSuccessLabel">Reservation Successful</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            Your reservation has been sucessfully added.
          </div>
        </div>
      </div>
    </div>

    @if (TempData["ReserveSuccess"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                localStorage.setItem('showSuccessModal', 'true');
            });
        </script>
    }

    <!-- Show success modal after reservation completion -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (localStorage.getItem('showSuccessModal') === 'true') {
                localStorage.removeItem('showSuccessModal');

                try {
                    var el = document.getElementById('reserveSuccessModal');
                    if (!el) {
                        console.warn('Success modal element not found');
                        return;
                    }

                    // Move modal to body if not already there
                    if (el.parentElement !== document.body) {
                        document.body.appendChild(el);
                    }

                    // Use a small delay to ensure DOM is ready
                    setTimeout(function() {
                        // Prefer bootstrap 5 API
                        if (window.bootstrap && typeof bootstrap.Modal === 'function') {
                            var inst = new bootstrap.Modal(el, { backdrop: true, keyboard: false });
                            inst.show();
                            return;
                        }

                        // Fallback to jQuery modal if available
                        if (window.jQuery && typeof jQuery.fn.modal === 'function') {
                            jQuery(el).modal('show');
                            return;
                        }

                        // Last resort - manually show modal
                        console.warn('Bootstrap modal not available, displaying fallback alert');
                        alert('Reservation successful');
                    }, 100);
                } catch (e) {
                    console.error('Error showing reservation success modal', e);
                }
            }
        });
    </script>
</div>