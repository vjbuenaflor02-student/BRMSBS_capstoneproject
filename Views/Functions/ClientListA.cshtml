@{
    ViewData["Title"] = "Manage Client Lists";
    Layout = "~/Views/Layouts/ClientListALayout.cshtml";
    var isSuccessModalVisible = TempData["ClientAdded"] != null;
}

<div class="text-ctr"><b> Manage Client Lists </b></div>

<div class="containerbox">
    <div style="margin-bottom:10px;">
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addClientModal">Add Client</button>
    </div>

    <!-- Clients table -->
    <div>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Action</th>
                    <th>Client ID</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Email Address</th>
                    <th>Contact Number</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && ((IEnumerable<BRMSBS_capstoneproject.Models.ClientModel>)Model).Any())
                {
                    foreach (var c in (IEnumerable<BRMSBS_capstoneproject.Models.ClientModel>)Model)
                    {
                        <tr>
                            <td>
                                <button type="button" 
                                        class="btn btn-outline-info btn-sm info-btn" 
                                        data-id="@c.Id" 
                                        data-firstname="@c.FirstName" 
                                        data-lastname="@c.LastName" 
                                        data-mi="@c.MI" 
                                        data-address="@c.Address" 
                                        data-email="@c.Email" 
                                        data-contactnumber="@c.ContactNumber" 
                                        data-nationality="@c.Nationality" 
                                        data-purpose="@c.Purpose">Info</button>

                                <button type="button" 
                                        class="btn btn-outline-primary btn-sm edit-btn" 
                                        data-id="@c.Id" 
                                        data-firstname="@c.FirstName" 
                                        data-lastname="@c.LastName" 
                                        data-mi="@c.MI" 
                                        data-address="@c.Address" 
                                        data-email="@c.Email" 
                                        data-contactnumber="@c.ContactNumber" 
                                        data-nationality="@c.Nationality" 
                                        data-purpose="@c.Purpose">Edit</button>

                                <button type="button" class="btn btn-outline-danger btn-sm delete-btn" data-id="@c.Id" data-name="@c.FirstName @c.LastName">Delete</button>
                            </td>
                            <td>@c.Id</td>
                            <td>@c.FirstName</td>
                            <td>@c.LastName</td>
                            <td>@c.Email</td>
                            <td>@c.ContactNumber</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">No clients found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


<!-- Add Client Modal -->
<div class="modal fade" id="addClientModal" tabindex="-1" aria-labelledby="addClientModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="addClientModalLabel">Add Client</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form method="post" action='@Url.Action("AddClient","System")'>
      <div class="modal-body">
        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">First Name</label>
            <div class="col-sm-10"><input name="FirstName" class="form-control" /></div>
        </div>
        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">Last Name</label>
            <div class="col-sm-10"><input name="LastName" class="form-control" /></div>
        </div>
        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">M.I.</label>
            <div class="col-sm-4"><input name="MI" class="form-control" /></div>
        </div>
        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">Address</label>
            <div class="col-sm-10"><input name="Address" class="form-control" /></div>
        </div>
        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">Email Address</label>
            <div class="col-sm-10">
                <div class="input-group">
                    <input name="Email" class="form-control" type="text" placeholder="example@domain.com" />
                </div>
            </div>
        </div>
        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">Contact Number</label>
            <div class="col-sm-10"><input name="ContactNumber" class="form-control" /></div>
        </div>
        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">Nationality</label>
            <div class="col-sm-10">
                <select name="Nationality" class="form-select">
                    <option value="">-- Select here --</option>
                    <option value="Filipino">Filipino</option>
                    <option value="Others">Others</option>
                </select>
            </div>
        </div>
        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">Purpose</label>
            <div class="col-sm-10"><input name="Purpose" class="form-control" /></div>
        </div>

        

      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <button type="submit" class="btn btn-primary">Add Client</button>
      </div>
      </form>
    </div>
  </div>
</div>

@if (TempData["ClientAdded"] != null)
{
    <div class="modal fade" id="successModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Success!</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center">Client added successfully.</div>
            </div>
        </div>
    </div>
}

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Ensure both modals are under document.body to avoid clipping and stacking issues
        try {
            var add = document.getElementById('addClientModal');
            var succ = document.getElementById('successModal');
            if (add && add.parentNode !== document.body) document.body.appendChild(add);
            if (succ && succ.parentNode !== document.body) document.body.appendChild(succ);
        } catch (e) { }

        var modalEl = document.getElementById('successModal');
        if (!modalEl) return;

        // Preferred: Bootstrap 5 API
        if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
            try { var bsModal = new bootstrap.Modal(modalEl); bsModal.show(); return; } catch (e) { }
        }

        // jQuery + bootstrap (older projects)
        if (window.jQuery && typeof jQuery.fn.modal === 'function') {
            try { $(modalEl).modal('show'); return; } catch (e) { }
        }

        // Fallback: manually display modal and backdrop
        modalEl.classList.add('show');
        modalEl.style.display = 'block';
        modalEl.style.zIndex = '200000';
        var backdrop = document.createElement('div');
        backdrop.className = 'modal-backdrop show';
        backdrop.style.backgroundColor = 'rgba(0,0,0,0.65)';
        backdrop.style.zIndex = '199990';
        backdrop.style.position = 'fixed';
        backdrop.style.top = '0';
        backdrop.style.left = '0';
        backdrop.style.width = '100%';
        backdrop.style.height = '100%';
        document.body.appendChild(backdrop);
    });
</script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
      try {
        var add = document.getElementById('addClientModal');
        if (add && add.parentNode !== document.body) document.body.appendChild(add);
      } catch (e) { }
    });
</script>



<style>
  /* Force backdrop immediately visible and keep modal above other elements */
  .modal { z-index: 200000 !important; }
  .modal-backdrop { background-color: rgba(0,0,0,0.65) !important; z-index: 199990 !important; }
</style>

<!-- Info Modal -->
<div class="modal fade" id="infoModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Client Info</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <dl class="row">
          <dt class="col-sm-3">ID</dt><dd class="col-sm-9" id="infoId"></dd>
          <dt class="col-sm-3">First Name</dt><dd class="col-sm-9" id="infoFirstName"></dd>
          <dt class="col-sm-3">Last Name</dt><dd class="col-sm-9" id="infoLastName"></dd>
          <dt class="col-sm-3">M.I.</dt><dd class="col-sm-9" id="infoMI"></dd>
          <dt class="col-sm-3">Address</dt><dd class="col-sm-9" id="infoAddress"></dd>
          <dt class="col-sm-3">Email</dt><dd class="col-sm-9" id="infoEmail"></dd>
          <dt class="col-sm-3">Contact Number</dt><dd class="col-sm-9" id="infoContact"></dd>
          <dt class="col-sm-3">Nationality</dt><dd class="col-sm-9" id="infoNationality"></dd>
          <dt class="col-sm-3">Purpose</dt><dd class="col-sm-9" id="infoPurpose"></dd>
        </dl>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<!-- Edit Client Modal (reuse add form layout) -->
<div class="modal fade" id="editClientModal" tabindex="-1" aria-labelledby="editClientModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="editClientModalLabel">Edit Client</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form method="post" action='@Url.Action("EditClient","System")'>
      <div class="modal-body">
        <input type="hidden" name="Id" id="editId" />
        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">First Name</label>
            <div class="col-sm-10"><input id="editFirstName" name="FirstName" class="form-control" /></div>
        </div>
        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">Last Name</label>
            <div class="col-sm-10"><input id="editLastName" name="LastName" class="form-control" /></div>
        </div>
        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">M.I.</label>
            <div class="col-sm-4"><input id="editMI" name="MI" class="form-control" /></div>
        </div>
        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">Address</label>
            <div class="col-sm-10"><input id="editAddress" name="Address" class="form-control" /></div>
        </div>
        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">Email Address</label>
            <div class="col-sm-10">
                <div class="input-group">
                    <input id="editEmail" name="Email" class="form-control" type="text" placeholder="example@domain.com" />
                </div>
            </div>
        </div>
        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">Contact Number</label>
            <div class="col-sm-10"><input id="editContactNumber" name="ContactNumber" class="form-control" /></div>
        </div>
        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">Nationality</label>
            <div class="col-sm-10">
                <select id="editNationality" name="Nationality" class="form-select">
                    <option value="">-- Select here --</option>
                    <option value="Filipino">Filipino</option>
                    <option value="Others">Others</option>
                </select>
            </div>
        </div>
        <div class="mb-3 row">
            <label class="col-sm-2 col-form-label">Purpose</label>
            <div class="col-sm-10"><input id="editPurpose" name="Purpose" class="form-control" /></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
      </form>
    </div>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-sm modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title">Confirm Delete</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center">
        Are you sure you want to delete <strong id="deleteClientName"></strong> ?
      </div>
      <div class="modal-footer">
        <form method="post" action='@Url.Action("DeleteClient","System")'>
            <input type="hidden" name="Id" id="deleteId" />
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-danger">Delete</button>
        </form>
      </div>
    </div>
  </div>
</div>

@* Edit/Delete success modals *@
@if (TempData["ClientEdited"] != null)
{
    <div class="modal fade" id="editSuccessModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Success!</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center">Client updated successfully.</div>
            </div>
        </div>
    </div>
}

@if (TempData["ClientDeleted"] != null)
{
    <div class="modal fade" id="deleteSuccessModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Success!</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center">Client deleted successfully.</div>
            </div>
        </div>
    </div>
}

<script>
document.addEventListener('DOMContentLoaded', function () {
    // delegate info buttons
    document.querySelectorAll('.info-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.getElementById('infoId').textContent = btn.dataset.id || '';
            document.getElementById('infoFirstName').textContent = btn.dataset.firstname || '';
            document.getElementById('infoLastName').textContent = btn.dataset.lastname || '';
            document.getElementById('infoMI').textContent = btn.dataset.mi || '';
            document.getElementById('infoAddress').textContent = btn.dataset.address || '';
            document.getElementById('infoEmail').textContent = btn.dataset.email || '';
            document.getElementById('infoContact').textContent = btn.dataset.contactnumber || '';
            document.getElementById('infoNationality').textContent = btn.dataset.nationality || '';
            document.getElementById('infoPurpose').textContent = btn.dataset.purpose || '';
            var modalEl = document.getElementById('infoModal');
            if (typeof bootstrap !== 'undefined' && bootstrap.Modal) new bootstrap.Modal(modalEl).show();
        });
    });

    // edit buttons
    document.querySelectorAll('.edit-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.getElementById('editId').value = btn.dataset.id || '';
            document.getElementById('editFirstName').value = btn.dataset.firstname || '';
            document.getElementById('editLastName').value = btn.dataset.lastname || '';
            document.getElementById('editMI').value = btn.dataset.mi || '';
            document.getElementById('editAddress').value = btn.dataset.address || '';
            document.getElementById('editEmail').value = btn.dataset.email || '';
            document.getElementById('editContactNumber').value = btn.dataset.contactnumber || '';
            document.getElementById('editNationality').value = btn.dataset.nationality || '';
            document.getElementById('editPurpose').value = btn.dataset.purpose || '';
            var modalEl = document.getElementById('editClientModal');
            if (typeof bootstrap !== 'undefined' && bootstrap.Modal) new bootstrap.Modal(modalEl).show();
        });
    });

    // delete buttons
    document.querySelectorAll('.delete-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.getElementById('deleteId').value = btn.dataset.id || '';
            document.getElementById('deleteClientName').textContent = btn.dataset.name || '';
            var modalEl = document.getElementById('deleteConfirmModal');
            if (typeof bootstrap !== 'undefined' && bootstrap.Modal) new bootstrap.Modal(modalEl).show();
        });
    });

    // show edit/delete success modals if present
    try {
        var editSucc = document.getElementById('editSuccessModal');
        if (editSucc && typeof bootstrap !== 'undefined' && bootstrap.Modal) new bootstrap.Modal(editSucc).show();
        var delSucc = document.getElementById('deleteSuccessModal');
        if (delSucc && typeof bootstrap !== 'undefined' && bootstrap.Modal) new bootstrap.Modal(delSucc).show();
    } catch (e) { }
});
</script>

